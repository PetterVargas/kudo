catalog:
  uuid: 777f8328-3fef-4ab9-b56d-3676534963f3
  metadata:
    title: Catálogo de Controles Kudo - Framework de Ciberseguridad en la Nube
    published: "2026-07-04T00:00:00Z"
    "last-modified": "2026-07-05T03:05:30Z"
    version: 0.1.0
    "oscal-version": 1.2.2
    remarks: "Catálogo OSCAL generado a partir de Kudo - Framework de Ciberseguridad. Contiene 8 dominios, 35 controles y 491 requisitos."
    props[3]{name,ns,value}:
      domain-count,"https://kudo.divisioncero.com/framework/oscal","8"
      control-count,"https://kudo.divisioncero.com/framework/oscal","35"
      requirement-count,"https://kudo.divisioncero.com/framework/oscal","491"
    links[2]{href,rel,"media-type",text}:
      "https://kudo.divisioncero.com/framework/oscal",canonical,text/html,Kudo y OSCAL
      "https://pages.nist.gov/OSCAL/",reference,text/html,Sitio oficial de OSCAL (NIST)
    roles[1]:
      - id: creator
        title: Peter Vargas
        links[1]{href,rel}:
          "https://petervargas.com",personal-page
    parties[1]:
      - uuid: ed04377f-1282-41a6-b653-477f0b38742c
        type: organization
        name: DivisionCero
        links[1]{href,rel}:
          "https://kudo.divisioncero.com",homepage
    "responsible-parties"[1]:
      - "role-id": creator
        "party-uuids"[1]: ed04377f-1282-41a6-b653-477f0b38742c
  groups[8]:
    - id: adr
      class: domain
      title: "Análisis, Detección y Respuesta de Ciberseguridad"
      props[1]{name,value}:
        label,ADR
      links[1]{href,rel,"media-type",text}:
        "https://kudo.divisioncero.com/framework/adr",reference,text/html,Documentación del dominio en el sitio Kudo
      parts[1]{id,name,prose}:
        adr_ovw,overview,"Dominio que establece las capacidades de monitoreo continuo, detección proactiva de amenazas y respuesta estructurada ante incidentes de seguridad. Incluye controles para la gestión e identificación de vulnerabilidades y su remediación, retención y monitoreo de registros de actividad (logs), y la atención formal de eventos e incidentes de ciberseguridad mediante playbooks y planes de respuesta. Integra capacidades de SIEM, threat intelligence, threat hunting y forense digital."
      controls[4]:
        - id: adr-1
          title: Protección contra Software Malicioso
          props[1]{name,value}:
            label,ADR-1
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/adr/adr-1",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: adr-1_smt
              name: statement
              prose: "Es necesario prevenir, detectar y neutralizar amenazas de software malicioso en toda la organización, desplegando soluciones de protección con capacidad de detección basada en comportamiento en endpoints, servidores y entornos cloud, y aplicando controles de contención como el whitelisting de aplicaciones y la cuarentena automática de amenazas. Es necesario proteger el correo electrónico y la navegación web frente a phishing, suplantación y contenido malicioso, y mantener alerta y capacitado al personal para reconocer y reportar comunicaciones sospechosas como complemento a las protecciones técnicas."
              parts[13]:
                - id: adr-1_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Implementamos controles para prevenir, detectar y neutralizar amenazas provenientes de software malicioso en todos los sistemas de la organización."
                - id: adr-1_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Desplegamos soluciones antimalware con capacidad de detección basada en comportamiento en endpoints, servidores y entornos cloud."
                - id: adr-1_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Alertamos a los colaboradores ante comunicaciones sospechosas detectadas.
                - id: adr-1_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Formamos adecuadamente a los usuarios en el reconocimiento y prevención de software malicioso como complemento a las protecciones técnicas implementadas.
                - id: adr-1_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Controlamos el acceso a sitios web externos para reducir la exposición a contenido malicioso o no autorizado según la política de uso aceptable de la organización.
                - id: adr-1_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Actualizamos continuamente las firmas y modelos de detección sin intervención manual.
                - id: adr-1_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Analizamos los archivos en sandbox antes de su ejecución (detonación controlada).
                - id: adr-1_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Detectamos técnicas de evasión avanzadas como fileless malware y living-off-the-land.
                - id: adr-1_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Implementamos listas de control de aplicaciones autorizadas (whitelisting) en todos los sistemas.
                - id: adr-1_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: "Aplicamos cuarentena automática ante la detección de amenazas en endpoints, servidores y entornos cloud."
                - id: adr-1_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Protegemos el correo electrónico corporativo con análisis de adjuntos en sandbox y verificación de URLs mediante sistemas de reputación en tiempo real.
                - id: adr-1_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: "Habilitamos DMARC, DKIM y SPF para la protección del correo electrónico contra phishing y suplantación."
                - id: adr-1_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: Implementamos filtrado de contenido web con bloqueo de dominios maliciosos conocidos y análisis SSL inspection.
        - id: adr-2
          title: "Gestión, Identificación y Remediación de Vulnerabilidades"
          props[1]{name,value}:
            label,ADR-2
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/adr/adr-2",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: adr-2_smt
              name: statement
              prose: "Es necesario recopilar y analizar inteligencia de amenazas y vulnerabilidades desde fuentes externas para anticipar riesgos, e implementar un programa continuo de identificación, priorización y remediación de vulnerabilidades en todos los activos tecnológicos mediante escaneos periódicos. Es necesario priorizar la remediación según la criticidad del activo y la severidad de la vulnerabilidad, dar seguimiento a su cumplimiento hasta el cierre, y gestionar formalmente las excepciones que no puedan remediarse en el plazo establecido."
              parts[13]:
                - id: adr-2_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Implementamos un programa continuo de identificación, clasificación, priorización y remediación de vulnerabilidades en todos los activos tecnológicos."
                - id: adr-2_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Ejecutamos escaneos de vulnerabilidades con frecuencia secuencial programada para sistemas críticos y para el resto del parque tecnológico.
                - id: adr-2_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Cubrimos un porcentaje definido de los activos registrados en el inventario con los escaneos de vulnerabilidades.
                - id: adr-2_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Priorizamos las vulnerabilidades basándonos en el score CVSS y la criticidad del activo afectado.
                - id: adr-2_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Importamos los resultados al sistema de gestión de tickets y los asignamos al propietario del activo para su remediación.
                - id: adr-2_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Aplicamos SLAs de remediación definido por criticidad de vulnerabilidad.
                - id: adr-2_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: "Exigimos aprobación de un líder, documentación de controles compensatorios y fecha máxima de resolución para las excepciones."
                - id: adr-2_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: "Recopilamos información sobre amenazas a la seguridad de la información proveniente de fuentes externas (CVE, advisories de fabricantes, feeds de inteligencia) para generar inteligencia útil sobre ellas."
                - id: adr-2_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Analizamos la información recopilada sobre amenazas a la seguridad de la información para generar inteligencia útil y accionable que oriente las decisiones de remediación.
                - id: adr-2_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: "Obtenemos información actualizada sobre las vulnerabilidades técnicas de los sistemas de información que usa la organización a través de fuentes externas autorizadas, complementando los resultados de los escaneos internos."
                - id: adr-2_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Monitoreamos automáticamente el cumplimiento de los SLAs y escalamos al responsable del área ante incumplimientos.
                - id: adr-2_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Verificamos la remediación de vulnerabilidades mediante reescaneo.
                - id: adr-2_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: Revisamos con frecuencia programada las excepciones vigentes.
        - id: adr-3
          title: Retención y Monitoreo de Registros
          props[1]{name,value}:
            label,ADR-3
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/adr/adr-3",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: adr-3_smt
              name: statement
              prose: "Es necesario generar, recolectar y centralizar en un SIEM los registros de actividad de los sistemas, aplicaciones e infraestructura relevantes para la seguridad de la información, garantizando su transmisión íntegra y su disponibilidad durante los períodos de retención definidos. Es necesario proteger los registros contra alteración o eliminación, y utilizarlos para detectar y alertar de forma oportuna comportamientos anómalos mediante monitoreo continuo desde el equipo de seguridad."
              parts[12]:
                - id: adr-3_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Recolectamos y centralizamos en un SIEM los logs de seguridad de todos los sistemas, aplicaciones e infraestructura de la organización."
                - id: adr-3_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Definimos y cubrimos las fuentes de logs obligatorias: sistemas operativos, aplicaciones críticas, firewalls, proxies, identity providers y sistemas cloud."
                - id: adr-3_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Transmitimos los logs en tiempo real al SIEM y validamos periódicamente la integridad del flujo de datos.
                - id: adr-3_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Retenemos los logs en almacenamiento activo en el SIEM durante un tiempo definido.
                - id: adr-3_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Retenemos los logs en almacenamiento de archivo por un período de tiempo definido.
                - id: adr-3_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Protegemos los logs archivados contra modificación mediante controles de inmutabilidad (WORM storage).
                - id: adr-3_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Implementamos reglas de correlación y detección en el SIEM para identificar comportamientos anómalos de alto interés.
                - id: adr-3_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: "Alertamos automáticamente ante: múltiples fallos de autenticación, accesos fuera de horario a sistemas críticos, exfiltración de datos, movimiento lateral y escalamiento de privilegios."
                - id: adr-3_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: "Habilitamos y configuramos la generación de registros de actividades, errores, fallos y otros eventos relevantes para la seguridad de la información en todos los sistemas origen."
                - id: adr-3_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: "Protegemos los registros en almacenamiento activo y en tránsito contra alteración o eliminación, complementando los controles de inmutabilidad aplicados al almacenamiento de archivo."
                - id: adr-3_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Inventariamos las fuentes de log y revisamos su cobertura con frecuencia programada.
                - id: adr-3_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Operamos dashboards de monitoreo continuo de seguridad desde el equipo de SOC.
        - id: adr-4
          title: Atención de Eventos y/o Incidentes de Ciberseguridad
          props[1]{name,value}:
            label,ADR-4
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/adr/adr-4",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: adr-4_smt
              name: statement
              prose: "Es necesario definir un proceso estructurado de respuesta a incidentes que cubra su detección, clasificación, contención, erradicación, recuperación y cierre, con tiempos de respuesta acordes a su severidad, y conformar un equipo de respuesta con roles definidos y disponibilidad para atender los incidentes más críticos. Es necesario mantener playbooks actualizados para los escenarios más frecuentes, incluyendo planes de mitigación masiva ante el compromiso generalizado de credenciales, y establecer canales claros para que el personal reporte eventos sospechosos. Es necesario preservar la evidencia de los incidentes garantizando la cadena de custodia, mantenerse conectado con comunidades especializadas del sector, y realizar análisis post-mortem que generen lecciones aprendidas para fortalecer los controles y actualizar los playbooks."
              parts[16]:
                - id: adr-4_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Definimos un proceso estructurado de respuesta a incidentes con etapas formales: detección, análisis, clasificación, contención, erradicación, recuperación y cierre."
                - id: adr-4_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Clasificamos los incidentes por severidad (P1 crítico, P2 alto, P3 medio, P4 bajo) con tiempos máximos de respuesta inicial y resolución definidos."
                - id: adr-4_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Conformamos un equipo de respuesta a incidentes (IRT/CSIRT) con roles y responsabilidades asignadas.
                - id: adr-4_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Garantizamos disponibilidad 24/7 del equipo de respuesta para incidentes de severidad P1 y P2.
                - id: adr-4_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: "Mantenemos playbooks de respuesta documentados y actualizados para los tipos de incidentes más frecuentes: ransomware, phishing dirigido, acceso no autorizado, fuga de datos y compromiso de cuentas privilegiadas."
                - id: adr-4_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: "Definimos en cada playbook los pasos específicos de contención, erradicación y recuperación."
                - id: adr-4_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Establecemos los umbrales de escalamiento y los criterios de notificación a reguladores dentro de los plazos legales aplicables.
                - id: adr-4_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: "Establecemos y mantenemos conexiones activas con grupos especializados, foros y asociaciones profesionales del ámbito de la seguridad de la información."
                - id: adr-4_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Proporcionamos un canal claro y accesible para que el personal reporte de forma oportuna cualquier evento de seguridad observado o sospechoso.
                - id: adr-4_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: "Establecemos procedimientos para identificar, recoger, adquirir y preservar evidencias relacionadas con eventos e incidentes de seguridad de la información."
                - id: adr-4_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Aplicamos los procedimientos de gestión de evidencias en todos los eventos e incidentes de seguridad garantizando la integridad de la cadena de custodia.
                - id: adr-4_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: "Definimos y mantenemos planes iniciales de mitigación masiva en protección de identidad que permitan ejecutar acciones a escala ante un compromiso generalizado de credenciales, incluyendo reset forzado masivo de contraseñas, habilitación de MFA de forma masiva y bloqueo de cuentas comprometidas."
                - id: adr-4_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: Realizamos análisis post-mortem obligatorio para todos los incidentes de severidad P1 y P2.
                - id: adr-4_smt.n
                  name: item
                  props[2]:
                    - name: label
                      value: n
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-14
                  prose: Actualizamos los playbooks tras cada incidente significativo incorporando las lecciones aprendidas.
                - id: adr-4_smt.o
                  name: item
                  props[2]:
                    - name: label
                      value: o
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-15
                  prose: Identificamos y registramos lecciones aprendidas para todos los incidentes de severidad P1 y P2.
                - id: adr-4_smt.p
                  name: item
                  props[2]:
                    - name: label
                      value: p
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-16
                  prose: Aprovechamos las lecciones aprendidas de los incidentes de seguridad para fortalecer y mejorar los controles de seguridad existentes más allá de la actualización de playbooks.
    - id: cap
      class: domain
      title: Ciberseguridad en Aplicaciones
      props[1]{name,value}:
        label,CAP
      links[1]{href,rel,"media-type",text}:
        "https://kudo.divisioncero.com/framework/cap",reference,text/html,Documentación del dominio en el sitio Kudo
      parts[1]{id,name,prose}:
        cap_ovw,overview,"Dominio dedicado a la protección y gestión segura del ciclo de vida completo del software (SDLC) incluyendo escenario con agentes de IA. Mediante threat modeling basados en el negocio integra controles de seguridad desde las fases de ideación, diseño y desarrollo hasta el despliegue y operación de aplicaciones y APIs. Contempla prácticas de DevSecOps, análisis estático (SAST) y dinámico (DAST) de vulnerabilidades, automatización en pipelines CI/CD, protección de ramas y codeowners, y el aseguramiento de interfaces de programación (APIs). Busca que todos los equipos de la compañía incorporen competencias de ciberseguridad para identificar y mitigar riesgos antes de llegar a producción, reduciendo la deuda técnica de seguridad y protegiendo la cadena de suministro del software."
      controls[2]:
        - id: cap-1
          title: Ciberseguridad en el Ciclo de Desarrollo del Software
          props[1]{name,value}:
            label,CAP-1
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cap/cap-1",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cap-1_smt
              name: statement
              prose: "Es necesario integrar la seguridad en todas las fases del ciclo de desarrollo del software bajo un enfoque Shift Left, realizando modelado de amenazas y definiendo requisitos de seguridad desde la planificación, y estableciendo principios de diseño seguro y estándares de codificación que guíen el desarrollo. Es necesario controlar el acceso al código fuente y a las herramientas de desarrollo, capacitar a los equipos en codificación segura, y automatizar en el pipeline de CI/CD la detección de secretos y el análisis de seguridad del código, las dependencias, los contenedores y la infraestructura como código. Es necesario bloquear el paso a producción de artefactos con vulnerabilidades críticas definiendo security gates y SLAs de remediación, gestionar de forma segura los secretos utilizados por las aplicaciones, y mantener separados y protegidos los entornos de desarrollo, prueba y producción."
              parts[30]:
                - id: cap-1_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Integramos prácticas de seguridad en todas las fases del SDLC bajo un enfoque Shift Left.
                - id: cap-1_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Realizamos modelado de amenazas de negocio en la fase de planificación de cada iniciativa de desarrollo.
                - id: cap-1_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Realizamos modelado de amenazas entre componentes arquitectónicos en la fase de planificación de cada iniciativa de desarrollo.
                - id: cap-1_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Definimos requisitos de seguridad funcionales y no funcionales antes de iniciar el diseño.
                - id: cap-1_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Revisamos la arquitectura de seguridad aplicando principios de Defense in Depth en la fase de diseño.
                - id: cap-1_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Definimos y mantenemos estándares de codificación segura basados en OWASP Top 10 y SANS CWE/25.
                - id: cap-1_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Capacitamos a los desarrolladores en codificación segura con frecuencia programada.
                - id: cap-1_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Definimos SLAs de remediación para los defectos de seguridad encontrados en las pruebas.
                - id: cap-1_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: "Gestionamos adecuadamente quién puede leer el código fuente, las herramientas de desarrollo y las bibliotecas de software."
                - id: cap-1_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: "Gestionamos adecuadamente quién puede modificar el código fuente, las herramientas de desarrollo y las bibliotecas de software."
                - id: cap-1_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Especificamos con claridad los requisitos de seguridad de la información al momento de desarrollar o adquirir nuevas aplicaciones.
                - id: cap-1_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Aprobamos formalmente los requisitos de seguridad de la información antes de desarrollar o adquirir nuevas aplicaciones.
                - id: cap-1_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: Documentamos los principios de diseño seguro de sistemas para que estén disponibles en todas las actividades de desarrollo.
                - id: cap-1_smt.n
                  name: item
                  props[2]:
                    - name: label
                      value: n
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-14
                  prose: Implementamos pre-commit hooks para verificar automáticamente el cumplimiento de los estándares de seguridad antes de aceptar código en el repositorio.
                - id: cap-1_smt.o
                  name: item
                  props[2]:
                    - name: label
                      value: o
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-15
                  prose: Implementamos workflows de CI/CD con protección de ramas y asignación de codeowners en todas las ramas principales del repositorio.
                - id: cap-1_smt.p
                  name: item
                  props[2]:
                    - name: label
                      value: p
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-16
                  prose: "Ejecutamos, tanto en el pipeline CI como en los pull requests, detección automática de secretos en el código fuente."
                - id: cap-1_smt.q
                  name: item
                  props[2]:
                    - name: label
                      value: q
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-17
                  prose: "Integramos análisis de seguridad estático (SAST) sobre el código fuente, ejecutándolo de forma automatizada en cada build del pipeline CI."
                - id: cap-1_smt.r
                  name: item
                  props[2]:
                    - name: label
                      value: r
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-18
                  prose: Integramos análisis dinámico (DAST) sobre la aplicación en ejecución en ambiente de staging como parte del pipeline CD.
                - id: cap-1_smt.s
                  name: item
                  props[2]:
                    - name: label
                      value: s
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-19
                  prose: "Integramos análisis de composición de software (SCA) para identificar vulnerabilidades en dependencias de terceros, ejecutándolo de forma automatizada en el pipeline CI."
                - id: cap-1_smt.t
                  name: item
                  props[2]:
                    - name: label
                      value: t
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-20
                  prose: Escaneamos las imágenes de contenedor en busca de vulnerabilidades como parte del pipeline CI.
                - id: cap-1_smt.u
                  name: item
                  props[2]:
                    - name: label
                      value: u
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-21
                  prose: Ejecutamos análisis estático de seguridad en toda la infraestructura definida como código (IaC).
                - id: cap-1_smt.v
                  name: item
                  props[2]:
                    - name: label
                      value: v
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-22
                  prose: Validamos las configuraciones desplegadas como parte del pipeline CD.
                - id: cap-1_smt.w
                  name: item
                  props[2]:
                    - name: label
                      value: w
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-23
                  prose: Definimos security gates automatizados con umbrales máximos de vulnerabilidades por severidad que bloquean el despliegue en producción de artefactos con vulnerabilidades críticas o altas.
                - id: cap-1_smt.x
                  name: item
                  props[2]:
                    - name: label
                      value: x
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-24
                  prose: Registramos los resultados de los security gates en el sistema de tickets de seguridad.
                - id: cap-1_smt.y
                  name: item
                  props[2]:
                    - name: label
                      value: y
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-25
                  prose: Gestionamos todos los secretos mediante servicios de vault e inyectamos en tiempo de ejecución.
                - id: cap-1_smt.z
                  name: item
                  props[2]:
                    - name: label
                      value: z
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-26
                  prose: "Integramos y verificamos automáticamente el firmado de commits en el SDLC, tanto en el pipeline CI como en los pull requests."
                - id: cap-1_smt.aa
                  name: item
                  props[2]:
                    - name: label
                      value: aa
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-27
                  prose: "Mantenemos separados los entornos de desarrollo, prueba y producción para evitar interferencias entre ellos."
                - id: cap-1_smt.ab
                  name: item
                  props[2]:
                    - name: label
                      value: ab
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-28
                  prose: "Protegemos los entornos de desarrollo, prueba y producción frente a accesos no autorizados o modificaciones indebidas."
                - id: cap-1_smt.ac
                  name: item
                  props[2]:
                    - name: label
                      value: ac
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-29
                  prose: Monitoreamos continuamente las vulnerabilidades en dependencias y aplicamos parches de seguridad.
                - id: cap-1_smt.ad
                  name: item
                  props[2]:
                    - name: label
                      value: ad
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-30
                  prose: Mantenemos actualizados los principios de diseño seguro de sistemas a lo largo del tiempo.
        - id: cap-2
          title: Ciberseguridad en APIs
          props[1]{name,value}:
            label,CAP-2
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cap/cap-2",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cap-2_smt
              name: statement
              prose: "Es necesario mantener un inventario actualizado de todas las APIs y monitorearlas continuamente, e implementar autenticación y autorización robustas que verifiquen la identidad y limiten el acceso según el principio de menor privilegio. Es necesario validar y sanitizar las entradas para prevenir inyecciones y otras vulnerabilidades del OWASP API Security Top 10, integrando pruebas de seguridad en el pipeline de desarrollo. Es necesario garantizar la disponibilidad del servicio mediante controles de rate limiting y circuit breakers, y proteger la información sensible que transita o se registra en las APIs."
              parts[13]:
                - id: cap-2_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Mantenemos un inventario completo y actualizado de todas las APIs con propietario, audiencia, versión y estado de ciclo de vida."
                - id: cap-2_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Definimos fecha de expiración para las API keys, las rotamos periódicamente y las revocamos al finalizar su uso."
                - id: cap-2_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: "Integramos pruebas de seguridad de APIs (DAST, fuzzing) en el pipeline CI/CD."
                - id: cap-2_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: "Implementamos autenticación robusta en todas las APIs mediante OAuth 2.0, OpenID Connect o JWT firmados con algoritmos seguros."
                - id: cap-2_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Implementamos mTLS para la autenticación mutua entre servicios en APIs críticas.
                - id: cap-2_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Implementamos autorización granular (RBAC/ABAC) siguiendo el principio de menor privilegio en todas las APIs.
                - id: cap-2_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Implementamos validación estricta de esquema (OpenAPI/Swagger) en todas las APIs.
                - id: cap-2_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: "Sanitizamos todos los inputs para prevenir inyecciones: SQL, NoSQL, command injection y XXE."
                - id: cap-2_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: "Implementamos rate limiting por usuario, IP y API key en todas las APIs."
                - id: cap-2_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Implementamos throttling y circuit breakers para garantizar la disponibilidad del servicio.
                - id: cap-2_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Enmascaramos los datos sensibles en los logs de API.
                - id: cap-2_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: "Implementamos headers de seguridad HTTP obligatorios: HSTS, CSP y X-Frame-Options."
                - id: cap-2_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: Monitoreamos continuamente todas las APIs inventariadas.
    - id: ccn
      class: domain
      title: Continuidad y Cambios del Negocio
      props[1]{name,value}:
        label,CCN
      links[1]{href,rel,"media-type",text}:
        "https://kudo.divisioncero.com/framework/ccn",reference,text/html,Documentación del dominio en el sitio Kudo
      parts[1]{id,name,prose}:
        ccn_ovw,overview,"Dominio enfocado en la resiliencia organizacional, la continuidad operacional y la gestión controlada de cambios en el entorno empresarial. Abarca los procedimientos de gestión y control de cambios, las pruebas de calidad y seguridad previas a los despliegues, y la capacidad de revertir cambios ante fallas (rollback). Promueve la identificación de puntos únicos de falla, el uso del modelo de responsabilidad compartida con proveedores de nube (CSP) y la implementación de estrategias de despliegue como blue/green. Su propósito es garantizar que los cambios tecnológicos no comprometan la disponibilidad de los servicios ni la experiencia de los clientes."
      controls[3]:
        - id: ccn-1
          title: Gestión y Control de Cambios
          props[1]{name,value}:
            label,CCN-1
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/ccn/ccn-1",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: ccn-1_smt
              name: statement
              prose: "Es necesario establecer un proceso formal para gestionar todos los cambios en sistemas, aplicaciones e infraestructura, clasificándolos según su tipo y exigiendo un análisis de impacto, un plan de rollback y una aprobación formal antes de su implementación. Es necesario conformar un comité de aprobación de cambios, definir ventanas de cambio y períodos de congelamiento acordes a la criticidad del negocio, y gestionar los cambios de emergencia mediante un proceso abreviado con aprobación mínima garantizada. Es necesario exigir que todo cambio recorra los ambientes definidos antes de llegar a producción, y apoyarse en el modelo de responsabilidad compartida del proveedor de nube para reducir la carga operativa de la gestión de cambios de infraestructura."
              parts[12]:
                - id: ccn-1_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Establecemos un proceso formal y estructurado para gestionar todos los cambios en sistemas, aplicaciones e infraestructura."
                - id: ccn-1_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Clasificamos los cambios en categorías: estándar, normal, emergencia y menor."
                - id: ccn-1_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Conformamos un Comité de Aprobación de Cambios (CAB) con representación de los principales líderes de cada cambio.
                - id: ccn-1_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Definimos ventanas de cambio programadas para la implementación de cambios normales.
                - id: ccn-1_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: "Establecemos períodos de freeze asociados a eventos críticos del negocio, temporadas de alta demanda, fechas del calendario fiscal, entre otros..."
                - id: ccn-1_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Documentamos para cada cambio los criterios de éxito y los contactos de escalamiento.
                - id: ccn-1_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Gestionamos los cambios de emergencia con un proceso abreviado que garantiza aprobación mínima de dos princiales aprobadores.
                - id: ccn-1_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Completamos la documentación post-implementación de los cambios de emergencia en un plazo con temporabilidad definida.
                - id: ccn-1_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Exigimos que todos los cambios recorran una cadena de ambientes definidas por la compañía antes de llegar a producción.
                - id: ccn-1_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Buscamos y aplicamos un modelo de responsabilidad compartida que favorezca al Cloud Service Provider (CSP) para reducir la carga operativa de la organización en la gestión de cambios de infraestructura.
                - id: ccn-1_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Identificamos los puntos únicos de falla a partir de la gráfica de la plataforma como parte del análisis de impacto de cada cambio.
                - id: ccn-1_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Implementamos despliegues automáticos en entornos separados de producción como parte de la cadena de ambientes del proceso de cambios.
        - id: ccn-2
          title: Pruebas de Calidad y Seguridad en la Gestión de Cambios
          props[1]{name,value}:
            label,CCN-2
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/ccn/ccn-2",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: ccn-2_smt
              name: statement
              prose: "Es necesario probar exhaustivamente todos los cambios en ambientes no productivos antes de su implementación en producción, exigiendo niveles mínimos de cobertura de pruebas y paridad de configuración con el ambiente productivo. Es necesario verificar la seguridad del código, las dependencias y la infraestructura afectada por el cambio, bloqueando el despliegue ante vulnerabilidades críticas, y validar el rendimiento del cambio bajo condiciones de carga cuando aplique. Es necesario requerir un plan de rollback funcional y la aprobación formal de calidad y seguridad antes de promover cualquier cambio, manteniendo evidencia de las pruebas realizadas."
              parts[12]:
                - id: ccn-2_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Probamos exhaustivamente todos los cambios en ambientes no productivos antes de su implementación en producción.
                - id: ccn-2_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Exigimos una cobertura mínima en pruebas unitarias como criterio de aprobación para la promoción entre ambientes.
                - id: ccn-2_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Garantizamos paridad de configuración entre el ambiente de staging y producción.
                - id: ccn-2_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Bloqueamos el despliegue ante cualquier vulnerabilidad crítica o alta detectada.
                - id: ccn-2_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Requerimos aprobación formal del equipo de calidad y seguridad para la promoción entre ambientes.
                - id: ccn-2_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Ejecutamos SAST sobre el código modificado antes de promover a producción.
                - id: ccn-2_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Ejecutamos DAST sobre la aplicación en ambiente de staging antes de promover a producción.
                - id: ccn-2_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Ejecutamos SCA para verificar la seguridad de las dependencias antes de cada despliegue.
                - id: ccn-2_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Realizamos escaneo de vulnerabilidades de infraestructura cuando aplique al cambio.
                - id: ccn-2_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Validamos el rendimiento dentro de los SLAs definidos antes de aprobar cada cambio.
                - id: ccn-2_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: "Realizamos pruebas de carga y rendimiento (load, stress, soak y spike testing) para cambios en sistemas críticos."
                - id: ccn-2_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Mantenemos registro de las pruebas realizadas como evidencia de cada cambio.
        - id: ccn-3
          title: Revertir Cambios
          props[1]{name,value}:
            label,CCN-3
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/ccn/ccn-3",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: ccn-3_smt
              name: statement
              prose: "Es necesario exigir un plan de rollback documentado y probado para todo cambio, definiendo con claridad los criterios que activan una reversión y los responsables de ejecutarla. Es necesario promover estrategias de despliegue que permitan revertir cambios en servicios críticos de forma inmediata y sin impacto a los usuarios. Es necesario registrar todo cambio revertido, analizar su causa raíz mediante un post-mortem, e incorporar las lecciones aprendidas al proceso de gestión de cambios."
              parts[10]:
                - id: ccn-3_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Exigimos un plan de rollback documentado y probado como requisito obligatorio en toda solicitud de cambio.
                - id: ccn-3_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Documentamos paso a paso los procedimientos de reversión para cada cambio.
                - id: ccn-3_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: "Definimos los criterios de activación del rollback: tiempos máximos de degradación, tasas de error y alertas de monitoreo."
                - id: ccn-3_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Asignamos responsables del proceso de reversión en cada cambio.
                - id: ccn-3_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Promovemos el uso de estrategias de despliegue blue/green o canary para cambios en servicios críticos.
                - id: ccn-3_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Garantizamos reversión inmediata sin impacto en los usuarios mediante las estrategias de despliegue seguro.
                - id: ccn-3_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: "Registramos en el sistema de gestión de cambios todos los cambios revertidos con su incidente, tiempo de afectación y causa del rollback."
                - id: ccn-3_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Realizamos análisis post-mortem obligatorio para todo cambio revertido en sistemas críticos.
                - id: ccn-3_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Identificamos la causa raíz del fallo y generamos acciones correctivas en cada post-mortem.
                - id: ccn-3_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Revisamos los post-mortems en el Comité Asesor de Cambios (CAB) e incorporamos las lecciones aprendidas al proceso de gestión de cambios.
    - id: cif
      class: domain
      title: Ciberseguridad en Infraestructura
      props[1]{name,value}:
        label,CIF
      links[1]{href,rel,"media-type",text}:
        "https://kudo.divisioncero.com/framework/cif",reference,text/html,Documentación del dominio en el sitio Kudo
      parts[1]{id,name,prose}:
        cif_ovw,overview,"Dominio que abarca la ciberseguridad integral de redes, servidores, plataformas tecnológicas y activos críticos de la organización. Incluye la gestión de proveedores de servicios en la nube (CSP), el inventario de activos, los controles de seguridad en redes y sistemas, el cifrado de información y datos, y la administración de claves criptográficas. Promueve la segmentación de redes, la restricción de accesos y el diseño de arquitecturas con superficie de ataque mínima, siguiendo el principio KISS (Keep It Simple and Secure). Atiende a la infraestructura como el componente más atacado del ecosistema tecnológico organizacional."
      controls[5]:
        - id: cif-1
          title: Proveedores de Servicio de Nube
          props[1]{name,value}:
            label,CIF-1
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cif/cif-1",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cif-1_smt
              name: statement
              prose: "Es necesario definir criterios formales para seleccionar proveedores de servicios en la nube, verificando sus certificaciones de seguridad y el modelo de responsabilidad compartida aplicable según el tipo de servicio. Es necesario realizar due diligence e incluir en los contratos garantías de disponibilidad, derecho de auditoría, notificación de incidentes y eliminación segura de datos al finalizar la relación. Es necesario evaluar periódicamente el riesgo de dependencia de un único proveedor y mantener una estrategia de diversificación para los servicios más críticos, gobernando todo el ciclo de contratación, uso y cierre de servicios en la nube."
              parts[7]:
                - id: cif-1_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Definimos criterios formales de selección para Cloud Service Provider (CSP).
                - id: cif-1_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Verificamos las certificaciones de seguridad vigentes de cada Cloud Service Provider (CSP).
                - id: cif-1_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: "Evaluamos el modelo de responsabilidad compartida según el tipo de servicio (IaaS, PaaS, SaaS, entre otros...)."
                - id: cif-1_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Incluimos en los contratos con Cloud Service Provider (CSP) SLAs de disponibilidad mínima acorde a la criticidad del servicio.
                - id: cif-1_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Mantenemos una estrategia documentada de multi-cloud o híbrida para servicios de alta criticidad y la revisamos anualmente.
                - id: cif-1_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: "Establecemos los procesos de contratación, uso, administración y cierre de servicios en la nube conforme a los requisitos de seguridad de la información de la organización."
                - id: cif-1_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Evaluamos periódicamente el riesgo de concentración en un único proveedor (vendor lock-in).
        - id: cif-2
          title: Inventario de Activos
          props[1]{name,value}:
            label,CIF-2
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cif/cif-2",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cif-2_smt
              name: statement
              prose: "Es necesario mantener un inventario automatizado y actualizado de todos los recursos desplegados en la nube, con un propietario asignado a cada activo y una reconciliación continua entre lo registrado y lo realmente desplegado. Es necesario etiquetar los recursos con los atributos mínimos que permitan identificarlos y protegerlos adecuadamente, verificando automáticamente su cumplimiento y corrigiendo las desviaciones. Es necesario detectar y eliminar los recursos huérfanos, usar la infraestructura como código como fuente de verdad del inventario, y gestionar los costos asociados a cada recurso."
              parts[13]:
                - id: cif-2_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Mantenemos actualizado el inventario de activos relacionados con la información mediante revisiones periódicas.
                - id: cif-2_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Mantenemos un inventario automatizado y completo de todos los recursos desplegados en entornos cloud.
                - id: cif-2_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Identificamos y registramos formalmente el responsable de cada activo incluido en el inventario como atributo obligatorio.
                - id: cif-2_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Definimos y aplicamos una política de etiquetado obligatorio (tagging) para todos los recursos cloud.
                - id: cif-2_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Establecemos la Infrastructure as Code (IaC) como fuente de verdad del inventario.
                - id: cif-2_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: "Registramos como atributos mínimos de etiquetado: entorno, propietario, centro de costos, aplicación, clasificación de datos y criticidad."
                - id: cif-2_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Aplicamos y verificamos las políticas de etiquetado automáticamente mediante políticas nativas del Cloud Service Provider (CSP).
                - id: cif-2_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Detectamos automáticamente los recursos cloud huérfanos que representan superficie de ataque innecesaria y costos evitables.
                - id: cif-2_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Eliminamos los recursos huérfanos no reclamados en el plazo definido.
                - id: cif-2_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Gestionamos los costos cloud por etiqueta con alertas de presupuesto definidas.
                - id: cif-2_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Validamos la reconciliación continua del inventario entre el estado real y el registrado.
                - id: cif-2_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Notificamos al propietario los recursos sin etiquetado completo y exigimos su corrección en un plazo máximo definido por la organización.
                - id: cif-2_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: Tratamos cualquier desviación entre el estado real y el IaC como una anomalía.
        - id: cif-3
          title: Ciberseguridad en la Red y Sistemas
          props[1]{name,value}:
            label,CIF-3
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cif/cif-3",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cif-3_smt
              name: statement
              prose: "Es necesario segmentar las redes aplicando el principio de mínimo acceso, proteger los recursos expuestos a internet frente a ataques externos, y aplicar hardening a los sistemas siguiendo referencias de la industria, manteniendo documentada y actualizada su configuración y topología. Es necesario restringir y supervisar estrictamente los accesos administrativos y privilegiados a los entornos productivos, habilitándolos de forma temporal y centralizando su registro para detectar actividad anómala. Es necesario proteger físicamente las instalaciones donde se procesa o almacena información mediante perímetros y controles de acceso, salvaguardar los equipos frente a amenazas físicas y ambientales, cortes de suministro y daños en el cableado, garantizar su mantenimiento adecuado, y aplicar prácticas de escritorio despejado y pantalla limpia dentro y fuera de las instalaciones."
              parts[31]:
                - id: cif-3_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Implementamos segmentación de red en entornos cloud con subnets diferenciadas por función: DMZ, aplicación, datos y gestión."
                - id: cif-3_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Aplicamos el principio default-deny en todos los controles de tráfico: security groups, NACLs y network policies."
                - id: cif-3_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Ubicamos los recursos críticos en subnets privadas sin acceso directo a internet.
                - id: cif-3_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Definimos y usamos perímetros de seguridad física para proteger las áreas donde se encuentre información y activos relacionados.
                - id: cif-3_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: "Diseñamos y aplicamos medidas de seguridad física para oficinas, despachos y otros espacios de trabajo."
                - id: cif-3_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Diseñamos y aplicamos procedimientos para trabajar de forma segura dentro de las áreas protegidas.
                - id: cif-3_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Ubicamos los equipos en lugares seguros y protegidos para reducir riesgos físicos.
                - id: cif-3_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Protegemos los activos de la organización cuando se encuentren fuera de sus instalaciones.
                - id: cif-3_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: "Nos aseguramos de que los equipos reciban el mantenimiento adecuado para garantizar la disponibilidad, integridad y confidencialidad de la información."
                - id: cif-3_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: "Definimos y documentamos las configuraciones de seguridad del hardware, software, servicios y redes de la organización."
                - id: cif-3_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Limitamos y supervisamos de forma rigurosa el uso de programas o herramientas que puedan saltarse o anular los controles de seguridad del sistema.
                - id: cif-3_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Aplicamos procedimientos y medidas para gestionar de forma segura la instalación de software en los sistemas que están en producción.
                - id: cif-3_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: "Identificamos los mecanismos de seguridad, los niveles de servicio y los requisitos de todos los servicios de red disponibles."
                - id: cif-3_smt.n
                  name: item
                  props[2]:
                    - name: label
                      value: n
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-14
                  prose: Restringimos los accesos a los entornos productivos aplicando el principio de mínimo privilegio y la política de máxima restricción posible.
                - id: cif-3_smt.o
                  name: item
                  props[2]:
                    - name: label
                      value: o
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-15
                  prose: Diagramamos los componentes y la topología de red de la infraestructura y mantenemos los diagramas actualizados ante cualquier cambio.
                - id: cif-3_smt.p
                  name: item
                  props[2]:
                    - name: label
                      value: p
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-16
                  prose: Implementamos WAF para la protección de todas las aplicaciones web expuestas a internet.
                - id: cif-3_smt.q
                  name: item
                  props[2]:
                    - name: label
                      value: q
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-17
                  prose: Implementamos protección DDoS en todos los recursos expuestos a internet.
                - id: cif-3_smt.r
                  name: item
                  props[2]:
                    - name: label
                      value: r
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-18
                  prose: Aplicamos hardening de sistemas y VMs basado en las referencias de industria mediante gestión de configuración centralizada.
                - id: cif-3_smt.s
                  name: item
                  props[2]:
                    - name: label
                      value: s
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-19
                  prose: Restringimos el acceso administrativo remoto exclusivamente a través de bastion hosts o servicios equivalentes con MFA obligatorio.
                - id: cif-3_smt.t
                  name: item
                  props[2]:
                    - name: label
                      value: t
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-20
                  prose: Aplicamos network policies en entornos Kubernetes para controlar el tráfico entre pods y servicios.
                - id: cif-3_smt.u
                  name: item
                  props[2]:
                    - name: label
                      value: u
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-21
                  prose: Habilitamos y centralizamos los flow logs de VPC/VNet en el SIEM para la detección de tráfico anómalo.
                - id: cif-3_smt.v
                  name: item
                  props[2]:
                    - name: label
                      value: v
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-22
                  prose: Protegemos las áreas seguras con controles de entrada y puntos de acceso adecuados que impidan el acceso no autorizado.
                - id: cif-3_smt.w
                  name: item
                  props[2]:
                    - name: label
                      value: w
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-23
                  prose: Diseñamos e implementamos protecciones para las infraestructuras frente a amenazas físicas y ambientales como desastres naturales u otros eventos inesperados.
                - id: cif-3_smt.x
                  name: item
                  props[2]:
                    - name: label
                      value: x
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-24
                  prose: Protegemos las instalaciones de procesamiento de información contra cortes de energía y otras interrupciones causadas por fallos en los suministros básicos.
                - id: cif-3_smt.y
                  name: item
                  props[2]:
                    - name: label
                      value: y
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-25
                  prose: "Protegemos el cableado eléctrico y de telecomunicaciones que transmite datos frente a interceptaciones, interferencias o daños."
                - id: cif-3_smt.z
                  name: item
                  props[2]:
                    - name: label
                      value: z
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-26
                  prose: Sincronizamos los relojes de todos los sistemas de procesamiento de información de la organización con fuentes de tiempo confiables y aprobadas.
                - id: cif-3_smt.aa
                  name: item
                  props[2]:
                    - name: label
                      value: aa
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-27
                  prose: "Configuramos cualquier cambio a nivel de nube mediante Privileged Identity Management (PIM), habilitando permisos privilegiados de forma temporal y bajo demanda (Just in Time)."
                - id: cif-3_smt.ab
                  name: item
                  props[2]:
                    - name: label
                      value: ab
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-28
                  prose: Revisamos trimestralmente las reglas de security groups y eliminamos los accesos no necesarios.
                - id: cif-3_smt.ac
                  name: item
                  props[2]:
                    - name: label
                      value: ac
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-29
                  prose: Grabamos todas las sesiones de acceso administrativo y las mantenemos disponibles para auditoría.
                - id: cif-3_smt.ad
                  name: item
                  props[2]:
                    - name: label
                      value: ad
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-30
                  prose: Monitorizamos de forma continua las instalaciones para detectar cualquier acceso físico no autorizado.
                - id: cif-3_smt.ae
                  name: item
                  props[2]:
                    - name: label
                      value: ae
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-31
                  prose: Supervisamos y ajustamos el uso de los recursos tecnológicos teniendo en cuenta las necesidades actuales y futuras de capacidad.
        - id: cif-4
          title: Cifrado de Información y Datos
          props[1]{name,value}:
            label,CIF-4
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cif/cif-4",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cif-4_smt
              name: statement
              prose: "Es necesario definir normas para el uso correcto de técnicas criptográficas y determinar el nivel de cifrado requerido según la clasificación de los datos. Es necesario cifrar la información en reposo con algoritmos estándar de la industria y gestionar las claves mediante servicios especializados, prohibiendo el uso de algoritmos y protocolos considerados débiles u obsoletos. Es necesario proteger las comunicaciones en tránsito exigiendo versiones seguras de TLS y HTTPS en todos los servicios expuestos, y verificar periódicamente el cumplimiento de estas prácticas."
              parts[13]:
                - id: cif-4_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Definimos normas para el uso correcto de técnicas criptográficas, incluyendo cómo gestionar las claves de cifrado."
                - id: cif-4_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Aplicamos normas para el uso correcto de técnicas criptográficas, incluyendo cómo gestionar las claves de cifrado."
                - id: cif-4_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Definimos el nivel de cifrado requerido en función de la clasificación de datos.
                - id: cif-4_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Habilitamos cifrado en reposo con un algoritmos criptográficos estándar de la industria o ampliamente aceptados por la industria en todos los servicios de almacenamiento cloud.
                - id: cif-4_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Usamos claves gestionadas por el cliente (CMK - Customer-Managed Keys) almacenadas en KMS (Key Management Service) para datos confidenciales y restringidos.
                - id: cif-4_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Prohibimos el uso de algoritmos criptográficos considerados débiles u obsoletos según los estándares vigentes de la industria.
                - id: cif-4_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: "Exigimos TLS 1.2 como versión mínima en todas las comunicaciones de datos en tránsito, con preferencia por TLS 1.3."
                - id: cif-4_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Hacemos obligatorio HTTPS en todas los servicios web expuestos.
                - id: cif-4_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Hacemos obligatorio HTTPS en todas las APIs expuestas.
                - id: cif-4_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Implementamos mTLS para comunicaciones service-to-service en arquitecturas de microservicios.
                - id: cif-4_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Implementamos HSTS con preload en todas las aplicaciones web.
                - id: cif-4_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: "Prohibimos el uso de protocolos inseguros: HTTP, FTP, Telnet y SNMPv1."
                - id: cif-4_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: Verificamos periódicamente el cumplimiento del cifrado mediante scans de configuración y análisis SSL/TLS.
        - id: cif-5
          title: Administración y Gestión de Claves
          props[1]{name,value}:
            label,CIF-5
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cif/cif-5",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cif-5_smt
              name: statement
              prose: "Es necesario gestionar el ciclo de vida completo de las claves criptográficas mediante servicios especializados, definiendo una jerarquía de claves y generándolas con métodos criptográficamente seguros. Es necesario proteger y rotar las claves con una frecuencia acorde a su criticidad, segregar su almacenamiento por ambiente, y distribuirlas únicamente a través de canales seguros separando las funciones entre administradores y usuarios. Es necesario auditar todas las operaciones criptográficas y destruir de forma segura las claves al finalizar su ciclo de vida."
              parts[11]:
                - id: cif-5_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Gestionamos el ciclo de vida completo de las claves criptográficas mediante servicios KMS gestionados.
                - id: cif-5_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Definimos e implementamos una jerarquía de claves criptográficas con Master Keys, Data Keys y API keys."
                - id: cif-5_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: "Segregamos el almacenamiento de claves por ambiente (producción, staging, desarrollo) con propietario definido para cada conjunto."
                - id: cif-5_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Seguimos un procedimiento documentado de destrucción segura al finalizar el ciclo de vida de cada clave.
                - id: cif-5_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Almacenamos las Master Keys en HSM con rotación con frecuencia programada.
                - id: cif-5_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Generamos las Data Keys mediante envelope encryption con rotación con frecuencia programada.
                - id: cif-5_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Rotamos las API keys con frecuencia programada.
                - id: cif-5_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Generamos las claves criptográficas con generadores de números aleatorios criptográficamente seguros (CSPRNG).
                - id: cif-5_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Distribuimos las claves únicamente mediante canales seguros y cifrados.
                - id: cif-5_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Implementamos técnicamente la separación de funciones entre el administrador y el usuario de claves.
                - id: cif-5_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Registramos en logs de auditoría todas las operaciones criptográficas.
    - id: cip
      class: domain
      title: Ciberseguridad en Identidad y Puntos Finales
      props[1]{name,value}:
        label,CIP
      links[1]{href,rel,"media-type",text}:
        "https://kudo.divisioncero.com/framework/cip",reference,text/html,Documentación del dominio en el sitio Kudo
      parts[1]{id,name,prose}:
        cip_ovw,overview,"Dominio orientado al control de acceso, gestión de identidades digitales y protección de dispositivos endpoints. Cubre el inventario completo de identidades, la autenticación multifactor (MFA), la autorización basada en roles (RBAC, ABAC, PBAC), el aprovisionamiento y desaprovisionamiento de usuarios, así como el inventario y aseguramiento de puntos finales (endpoints). Promueve la estrategia Zero Trust como principio rector, priorizando la gestión de identidades 100% en la nube y la integración con Single Sign On SSO. Es considerado el pilar inicial de protección más relevante de la organización, dado que la identidad representa el principal vector de ataque en entornos modernos."
      controls[6]:
        - id: cip-1
          title: Inventario de Identidad
          props[1]{name,value}:
            label,CIP-1
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cip/cip-1",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cip-1_smt
              name: statement
              prose: "Es necesario mantener un inventario completo y actualizado de todas las identidades humanas y no humanas con acceso a recursos organizacionales, integrado con el proveedor de identidad y el sistema de recursos humanos para reflejar su estado real. Es necesario gestionar el ciclo de vida de cada identidad desde su creación hasta su baja, asignar un propietario y un propósito a cada identidad no humana, y desactivar aquellas que ya no tengan uso o propietario activo."
              parts[12]:
                - id: cip-1_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Mantenemos un registro completo y actualizado de todas las identidades —humanas— que tienen acceso a recursos organizacionales.
                - id: cip-1_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Mantenemos un registro completo y actualizado de todas las identidades —no humanas— que tienen acceso a recursos organizacionales.
                - id: cip-1_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: "Definimos los atributos mínimos del inventario de identidades: ID único, tipo, estado, propietario, última actividad y fecha de revisión."
                - id: cip-1_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: "Definimos los mecanismos de gestión del ciclo de vida de las identidades: onboarding."
                - id: cip-1_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: "Definimos los mecanismos de gestión del ciclo de vida de las identidades: cambios."
                - id: cip-1_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: "Definimos los mecanismos de gestión del ciclo de vida de las identidades: offboarding."
                - id: cip-1_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: "Asignamos a cada identidad no humana un propietario humano, un propósito documentado y una fecha de expiración."
                - id: cip-1_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Integramos el inventario de identidades con el proveedor de identidad centralizado (IdP).
                - id: cip-1_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Integramos el inventario de identidades con el sistema de RRHH (HRIS - Human Resources Information System).
                - id: cip-1_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: "Gestionamos un IdP 100% en nube en modelos responsabilidad compartida SaaS, como por ejemplo: EntraID."
                - id: cip-1_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Reconciliamos automáticamente el inventario IdP con una frecuencia programada.
                - id: cip-1_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Identificamos y desactivamos las identidades no humanas sin propietario activo o sin uso en un período definido por la organización.
        - id: cip-2
          title: Ciberseguridad en Autenticación
          props[1]{name,value}:
            label,CIP-2
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cip/cip-2",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cip-2_smt
              name: statement
              prose: "Es necesario establecer una política de control de acceso que formalice la asignación de credenciales, exigiendo autenticación multifactor en los accesos administrativos, remotos y a sistemas críticos, y centralizando la autenticación mediante un proveedor único (SSO). Es necesario aplicar políticas de contraseñas seguras, promover mecanismos de autenticación más robustos, y monitorear y revocar de inmediato las credenciales comprometidas. Es necesario gestionar de forma segura la autenticación entre servicios y aplicaciones mediante identidades administradas, rotar automáticamente las claves y tokens utilizados, y orientar a los colaboradores en el manejo correcto de sus credenciales."
              parts[13]:
                - id: cip-2_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Tenemos una política de control de acceso establecida en la compañía.
                - id: cip-2_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Orientamos a los colaboradores sobre manejar correctamente la identidades y promovemos el uso de gestores de contraseñas.
                - id: cip-2_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Controlamos la asignación de credenciales de acceso mediante un proceso formal y estructurado.
                - id: cip-2_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Exigimos aprobación formal del responsable de ciberseguridad y controles compensatorios documentados para cualquier exención del MFA.
                - id: cip-2_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: "Implementamos MFA obligatorio en todos los accesos administrativos, remotos y a sistemas y datos críticos o confidenciales."
                - id: cip-2_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Soportamos múltiples factores de segunda verificación acorde al riesgo del acceso.
                - id: cip-2_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: "Implementamos Single Sign On SSO corporativo basado en protocolos estándar (SAML 2.0, OAuth 2.0, OIDC) para centralizar la autenticación."
                - id: cip-2_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Aplicamos políticas de contraseñas con criterios de seguridad.
                - id: cip-2_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: "Promovemos la autenticación sin contraseña (FIDO2, Windows Hello) como evolución hacia arquitecturas más seguras."
                - id: cip-2_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Usamos managed identities o service principals con permisos mínimos para la autenticación entre servicios y aplicaciones.
                - id: cip-2_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Rotamos automáticamente las API keys y tokens de servicio según la periodicidad establecida.
                - id: cip-2_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Aceptamos software de tercero que permita el aprovisionamiento y desaprovisionamiento automatico (SCIM)
                - id: cip-2_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: Monitoreamos continuamente las credenciales comprometidas y las revocamos de inmediato al ser detectadas.
        - id: cip-3
          title: Ciberseguridad en Autorización
          props[1]{name,value}:
            label,CIP-3
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cip/cip-3",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cip-3_smt
              name: statement
              prose: "Es necesario aplicar el principio de mínimo privilegio en todos los controles de acceso físico y digital, utilizando modelos de autorización basados en roles, atributos y políticas que permitan decisiones de acceso dinámicas y contextuales. Es necesario otorgar los privilegios elevados de forma temporal y bajo aprobación, revisar periódicamente los permisos otorgados para revocar los que ya no sean necesarios, y detectar los conflictos de segregación de funciones. Es necesario registrar las sesiones privilegiadas para su auditoría, y establecer reglas de acceso físico a instalaciones y salas críticas acordes a las necesidades del negocio."
              parts[11]:
                - id: cip-3_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Implementamos el principio de mínimo privilegio en todos los controles de acceso.
                - id: cip-3_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Establecemos y aplicamos reglas de control de acceso físico a instalaciones, salas de servidores y activos relacionados, basadas en las necesidades del negocio y de seguridad."
                - id: cip-3_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: "Restringimos el acceso físico y digital a la información y activos relacionados según las políticas de control de acceso definidas, aplicando el principio de mínimo privilegio."
                - id: cip-3_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Implementamos un modelo de control de acceso basado en roles (RBAC) donde los permisos se asignan según la función de cada usuario.
                - id: cip-3_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Implementamos políticas de control de acceso basadas en atributos (ABAC) para decisiones dinámicas y contextuales.
                - id: cip-3_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Implementamos políticas centralizadas de control de acceso (PBAC) evaluadas en tiempo real.
                - id: cip-3_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: "Implementamos acceso Just-in-Time (JIT) para privilegios elevados, con duración limitada y aprobación mediante workflow."
                - id: cip-3_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Realizamos revisiones en periodos frecuentes de permisos por propietario del sistema y responsable del área.
                - id: cip-3_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Revocamos los accesos que ya no son necesarios durante las revisiones de permisos.
                - id: cip-3_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Detectamos automáticamente los conflictos de segregación de funciones.
                - id: cip-3_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Grabamos y mantenemos disponibles para revisión forense y auditoría todas las sesiones privilegiadas.
        - id: cip-4
          title: "Aprovisionamiento, Cambios y Desaprovisionamiento de Identidades"
          props[1]{name,value}:
            label,CIP-4
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cip/cip-4",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cip-4_smt
              name: statement
              prose: "Es necesario automatizar el ciclo de vida completo de las identidades bajo el modelo Joiner-Mover-Leaver, disparando el aprovisionamiento de accesos desde el sistema de recursos humanos según plantillas de rol aprobadas, y garantizando que cada colaborador cuente oportunamente con los accesos que necesita. Es necesario revocar y reasignar automáticamente los accesos ante cambios de rol validando que no generen conflictos de segregación de funciones, y desactivar de inmediato todos los accesos al finalizar la relación laboral. Es necesario auditar periódicamente estos procesos para garantizar su correcto funcionamiento."
              parts[11]:
                - id: cip-4_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Automatizamos el ciclo de vida completo de identidades siguiendo el modelo Joiner-Mover-Leaver.
                - id: cip-4_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Garantizamos que el nuevo colaborador disponga de todos sus accesos en un plazo máximo definido por la organización desde el inicio de actividades.
                - id: cip-4_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Completamos el desaprovisionamiento en un plazo máximo definido por la organización desde la notificación de RRHH.
                - id: cip-4_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Disparamos el aprovisionamiento de accesos automáticamente desde el HRIS al momento de la contratación.
                - id: cip-4_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: "Asignamos cuentas, licencias de software y accesos según plantillas de rol predefinidas y aprobadas."
                - id: cip-4_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Registramos cada acceso otorgado en el sistema de gestión de identidades con trazabilidad del proceso de aprobación.
                - id: cip-4_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Revocamos los accesos del rol anterior y asignamos los nuevos automáticamente ante cambios de cargo o área.
                - id: cip-4_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: "Desactivamos la cuenta, revocamos todos los accesos y cerramos forzosamente las sesiones activas ante la terminación de la relación laboral."
                - id: cip-4_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Validamos la ausencia de conflictos de segregación de funciones en cada cambio de rol.
                - id: cip-4_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Auditamos con frecuencia programada el proceso de aprovisionamiento.
                - id: cip-4_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Auditamos con frecuencia programada el proceso de desaprovisionamiento.
        - id: cip-5
          title: Inventario de Puntos Finales
          props[1]{name,value}:
            label,CIP-5
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cip/cip-5",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cip-5_smt
              name: statement
              prose: "Es necesario mantener un inventario completo y actualizado de todos los dispositivos endpoint que acceden a la red o a los recursos organizacionales, automatizando su descubrimiento y registrando los atributos que permitan identificar su estado y nivel de cumplimiento. Es necesario detectar y aislar los dispositivos no autorizados que intenten conectarse, reconciliar periódicamente el inventario físico con el lógico, y gestionar el ciclo de vida de cada dispositivo desde su adquisición hasta su retiro, garantizando el borrado seguro de la información antes de su disposición final."
              parts[7]:
                - id: cip-5_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Mantenemos un inventario completo y actualizado de todos los dispositivos endpoint que acceden a la red corporativa o a recursos organizacionales.
                - id: cip-5_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Registramos para cada dispositivo: hostname, dirección MAC, número de serie, sistema operativo, usuario asignado, estado del agente EDR, estado de cifrado y estado de compliance."
                - id: cip-5_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Gestionamos el ciclo de vida de los dispositivos desde su adquisición hasta su retiro.
                - id: cip-5_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Automatizamos el descubrimiento de dispositivos mediante agentes MDM/UEM y escaneos de red.
                - id: cip-5_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Detectamos los dispositivos no autorizados que intentan conectarse a la red y los bloqueamos o redirigimos a cuarentena.
                - id: cip-5_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Aplicamos borrado certificado de datos antes de la disposición final de cada dispositivo o en reasignación.
                - id: cip-5_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Reconciliamos el inventario físico con el lógico con una frecuencia programada.
        - id: cip-6
          title: Ciberseguridad en Puntos Finales
          props[1]{name,value}:
            label,CIP-6
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cip/cip-6",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cip-6_smt
              name: statement
              prose: "Es necesario proteger los dispositivos endpoint desplegando soluciones de detección y respuesta con análisis de comportamiento, integradas con el SIEM para la correlación de alertas y la respuesta coordinada a incidentes. Es necesario aplicar hardening a los sistemas operativos, cifrar la información almacenada, y mantener los dispositivos actualizados mediante una gestión automatizada de parches, identificando y notificando aquellos que se encuentren en incumplimiento. Es necesario controlar qué aplicaciones y dispositivos externos pueden ejecutarse o conectarse a cada endpoint, prevenir la fuga de información sensible, y contar con la capacidad de ubicar y borrar remotamente la información de un dispositivo cuando sea necesario."
              parts[13]:
                - id: cip-6_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Desplegamos soluciones EDR/XDR en el 100% de los dispositivos endpoint corporativos con análisis de comportamiento avanzado.
                - id: cip-6_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Gestionamos las excepciones a los controles de endpoint mediante un proceso formal de aprobación con fecha de expiración.
                - id: cip-6_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Integramos las soluciones EDR/XDR con el SIEM/SOC para la correlación de alertas y la respuesta coordinada a incidentes.
                - id: cip-6_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Actualizamos automáticamente las firmas y motores de detección de las soluciones EDR/XDR.
                - id: cip-6_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: "Aplicamos hardening de sistema operativo basado en CIS Benchmarks para Windows, macOS y Linux mediante gestión de configuración centralizada."
                - id: cip-6_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Habilitamos el cifrado completo de disco en todos los dispositivos con gestión centralizada de recovery keys.
                - id: cip-6_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Automatizamos la gestión de parches con SLAs definidos.
                - id: cip-6_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Implementamos control de aplicaciones mediante whitelisting para que solo se ejecuten aplicaciones aprobadas.
                - id: cip-6_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Restringimos el uso de dispositivos de almacenamiento USB no autorizados en todos los endpoints.
                - id: cip-6_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Implementamos controles de prevención de pérdida de datos (DLP) en endpoints para detectar y bloquear la exfiltración de datos sensibles.
                - id: cip-6_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Ubicamos los endpoints geográficamente en caso de ser necesario.
                - id: cip-6_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Borramos remotamente sin posibilidad de recuperación de información almacenada en el endpoint.
                - id: cip-6_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: Identificamos y notificamos automáticamente los dispositivos en estado de non-compliance.
    - id: cor
      class: domain
      title: Coherencia Organizacional
      props[1]{name,value}:
        label,COR
      links[1]{href,rel,"media-type",text}:
        "https://kudo.divisioncero.com/framework/cor",reference,text/html,Documentación del dominio en el sitio Kudo
      parts[1]{id,name,prose}:
        cor_ovw,overview,"Establece la base de gobernanza, estrategia y cumplimiento de Ciberseguridad; asegurando que las políticas, procedimientos y controles documentados reflejen la realidad estratégica, operativa y los acuerdos llegados con los stakeholders. Comprende la gestión de riesgos organizacionales, el mapeo de cumplimiento regulatorio, la evaluación independiente basada en riesgos y los mecanismos de mejora continua y acciones correctivas. Su objetivo central es alinear los objetivos de negocio con la estrategia de Ciberseguridad a través de estructuras de gobierno efectivas, roles definidos, ciclos de revisión y auditoría periódicos."
      controls[4]:
        - id: cor-1
          title: Programa de Gestión de Riesgos y Ciberseguridad
          props[1]{name,value}:
            label,COR-1
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cor/cor-1",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cor-1_smt
              name: statement
              prose: "Es necesario crear un Sistema de Gestión de Seguridad de la Información, definiendo su alcance a partir del contexto organizacional y las necesidades de sus grupos de interés, y designar un responsable de ciberseguridad con roles, recursos y una estructura de gobierno revisada periódicamente por la alta dirección. Es necesario documentar, aprobar y comunicar las políticas, procesos y procedimientos del sistema de gestión, e implementar una metodología de gestión de riesgos que permita identificarlos, priorizarlos y asignarles un responsable y un plan de tratamiento. Es necesario alinear las iniciativas de ciberseguridad con los objetivos del negocio mediante un roadmap priorizado, reportar periódicamente su avance y los indicadores de gestión a la alta dirección, e impulsar desde el liderazgo la mejora continua del sistema."
              parts[37]:
                - id: cor-1_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Creamos el Sistema de Gestión de Seguridad de la Información (SGSI).
                - id: cor-1_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Definimos el alcance del SGSI considerando el contexto, los stakeholders y su conexión con otras organizaciones."
                - id: cor-1_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: "Identificamos los factores del entorno interno, externo y de terceras partes que pueden afectar el SGSI y el logro de sus metas."
                - id: cor-1_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Identificamos los stakeholders del SGSI.
                - id: cor-1_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Identificamos las necesidades y expectativas de los stakeholders del SGSI.
                - id: cor-1_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Determinamos cuáles necesidades y expectativas de los stakeholders serán atendidas por el SGSI.
                - id: cor-1_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Designamos un responsable de Ciberseguridad en la compañía.
                - id: cor-1_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Definimos los roles y responsabilidades o la matriz RACI del SGSI.
                - id: cor-1_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Garantizamos que el SGSI cuente con los recursos necesarios para su funcionamiento.
                - id: cor-1_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Creamos una política de seguridad de la información que se ajuste a lo que hace y necesita la organización.
                - id: cor-1_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Creamos una política de seguridad de la información que incluye objetivos claros de seguridad o que sirve como guía para definirlos.
                - id: cor-1_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: "Creamos una política de seguridad de la información que incluye el compromiso de cumplir con todas las reglas, requisitos y stakeholders que defina la organización."
                - id: cor-1_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: Creamos una política de seguridad de la información que incluye el compromiso de mejorar constantemente el sistema de gestión.
                - id: cor-1_smt.n
                  name: item
                  props[2]:
                    - name: label
                      value: n
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-14
                  prose: Creamos y mejoramos continuamente los documentos sobre las políticas de la compañía.
                - id: cor-1_smt.o
                  name: item
                  props[2]:
                    - name: label
                      value: o
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-15
                  prose: Creamos y mejoramos continuamente los documentos sobre los procesos de la compañía.
                - id: cor-1_smt.p
                  name: item
                  props[2]:
                    - name: label
                      value: p
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-16
                  prose: Creamos y mejoramos continuamente los documentos sobre los procedimientos de la compañía.
                - id: cor-1_smt.q
                  name: item
                  props[2]:
                    - name: label
                      value: q
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-17
                  prose: "Documentamos los dominios, controles y requisitos del SGSI."
                - id: cor-1_smt.r
                  name: item
                  props[2]:
                    - name: label
                      value: r
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-18
                  prose: "Aprobamos, comunicamos y versionamos los documentos del SGSI."
                - id: cor-1_smt.s
                  name: item
                  props[2]:
                    - name: label
                      value: s
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-19
                  prose: Garantizamos que los interesados reconozcan y conozcan los documentos del SGSI.
                - id: cor-1_smt.t
                  name: item
                  props[2]:
                    - name: label
                      value: t
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-20
                  prose: Integramos los requisitos del SGSI a los procesos de la organización.
                - id: cor-1_smt.u
                  name: item
                  props[2]:
                    - name: label
                      value: u
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-21
                  prose: "Establecemos un procedimiento para la gestión y recolección centralizada de evidencias para los requisitos y controles de Ciberseguridad, garantizando su disponibilidad para los stakeholders."
                - id: cor-1_smt.v
                  name: item
                  props[2]:
                    - name: label
                      value: v
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-22
                  prose: Implementamos una metodología para la gestión de los riesgos.
                - id: cor-1_smt.w
                  name: item
                  props[2]:
                    - name: label
                      value: w
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-23
                  prose: Declaramos el apetito de riesgos de la organización.
                - id: cor-1_smt.x
                  name: item
                  props[2]:
                    - name: label
                      value: x
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-24
                  prose: Declaramos la tolerancia de riesgos de la organización.
                - id: cor-1_smt.y
                  name: item
                  props[2]:
                    - name: label
                      value: y
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-25
                  prose: "Incorporamos en la metodología de riesgos criterios de valoración de activos, amenazas y vulnerabilidades."
                - id: cor-1_smt.z
                  name: item
                  props[2]:
                    - name: label
                      value: z
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-26
                  prose: "Asignamos a cada riesgo un propietario, un nivel de riesgo residual y un plan de tratamiento."
                - id: cor-1_smt.aa
                  name: item
                  props[2]:
                    - name: label
                      value: aa
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-27
                  prose: Formulamos un roadmap de ciberseguridad.
                - id: cor-1_smt.ab
                  name: item
                  props[2]:
                    - name: label
                      value: ab
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-28
                  prose: Priorizamos las iniciativas de ciberseguridad con responsables y fechas de implementación.
                - id: cor-1_smt.ac
                  name: item
                  props[2]:
                    - name: label
                      value: ac
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-29
                  prose: Alineamos las iniciativas de ciberseguridad a los objetivos del negocio.
                - id: cor-1_smt.ad
                  name: item
                  props[2]:
                    - name: label
                      value: ad
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-30
                  prose: Registramos los riesgos identificados en un repositorio centralizado.
                - id: cor-1_smt.ae
                  name: item
                  props[2]:
                    - name: label
                      value: ae
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-31
                  prose: Revisamos anualmente la estructura de gobierno y la sometemos a aprobación de la alta dirección.
                - id: cor-1_smt.af
                  name: item
                  props[2]:
                    - name: label
                      value: af
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-32
                  prose: Realizamos comités de seguridad o reportes con una frecuencia programada a la alta dirección.
                - id: cor-1_smt.ag
                  name: item
                  props[2]:
                    - name: label
                      value: ag
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-33
                  prose: "Incluimos en los reportes y revisiones gerenciales el estado de riesgos críticos, el avance del roadmap, los indicadores de incidentes, el cumplimiento regulatorio, el desempeño de controles, las tendencias en incumplimientos, los resultados de mediciones y auditorías, el cumplimiento de objetivos, los resultados de la evaluación de riesgos, el avance del plan de tratamiento de riesgos y el avance de mejoras."
                - id: cor-1_smt.ah
                  name: item
                  props[2]:
                    - name: label
                      value: ah
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-34
                  prose: Definimos y hacemos seguimiento a los OKRs de seguridad de la información y ciberseguridad.
                - id: cor-1_smt.ai
                  name: item
                  props[2]:
                    - name: label
                      value: ai
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-35
                  prose: Definimos y hacemos seguimiento a los KPIs de seguridad de la información y ciberseguridad.
                - id: cor-1_smt.aj
                  name: item
                  props[2]:
                    - name: label
                      value: aj
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-36
                  prose: "Mejoramos continuamente el SGSI, revisamos y actualizamos los documentos con una frecuencia programada junto con sus interesados."
                - id: cor-1_smt.ak
                  name: item
                  props[2]:
                    - name: label
                      value: ak
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-37
                  prose: Impulsamos desde el liderazgo la mejora continua del SGSI.
        - id: cor-2
          title: Mapeo de Cumplimiento Regulatorio
          props[1]{name,value}:
            label,COR-2
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cor/cor-2",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cor-2_smt
              name: statement
              prose: "Es necesario mapear y documentar todas las obligaciones legales, regulatorias y contractuales aplicables a la organización, clasificarlas y asignarles un responsable de cumplimiento, y monitorear los cambios normativos para mantener el inventario actualizado. Es necesario construir una matriz que relacione cada obligación con los controles de ciberseguridad implementados, e identificar y cerrar las brechas de cumplimiento detectadas."
              parts[9]:
                - id: cor-2_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Mapeamos y documentamos en el contexto legal todas las obligaciones aplicables a la organización en los países donde operamos.
                - id: cor-2_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Mapeamos y documentamos en el contexto regulatorio todas las obligaciones aplicables a la organización en los países donde operamos.
                - id: cor-2_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Mapeamos y documentamos en el contexto contractual todas las obligaciones aplicables basadas en los términos y condiciones de nuestros clientes.
                - id: cor-2_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: "Clasificamos las obligaciones legales, regulatorias y contractuales por jurisdicción y tipo de obligación."
                - id: cor-2_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Asignamos un responsable de cumplimiento por cada regulación identificada en el inventario.
                - id: cor-2_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Definimos la periodicidad de revisión y registramos el estado de cumplimiento actual de cada obligación en el inventario.
                - id: cor-2_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: "Construimos una matriz de cumplimiento que mapea cada requisito legal, regulatorio y contractual a los controles de ciberseguridad implementados."
                - id: cor-2_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: "Monitoreamos con frecuencia programada los cambios legales, regulatorios y contracturales; y actualizamos el inventario."
                - id: cor-2_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: "Identificamos brechas de cumplimiento legal, regulatorio y contractual; y generamos planes de acción para su cierre."
        - id: cor-3
          title: Evaluación Independiente basada en Riesgos
          props[1]{name,value}:
            label,COR-3
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cor/cor-3",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cor-3_smt
              name: statement
              prose: "Es necesario mantener programas de auditoría interna y externa con alcance definido según el perfil de riesgo, garantizando la independencia de los auditores y ejecutándolas con una frecuencia acorde a la criticidad de los sistemas evaluados. Es necesario contratar periódicamente evaluaciones de terceros independientes que incluyan pruebas técnicas y de madurez, presentando sus resultados a la alta dirección y planificando su ejecución para minimizar el impacto en producción. Es necesario gestionar de forma centralizada las evidencias de cumplimiento, y definir qué, cómo y cuándo se debe medir y evaluar el desempeño de la seguridad de la información."
              parts[17]:
                - id: cor-3_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Definimos un programa de auditorías internas de ciberseguridad con alcance basado en el perfil de riesgo.
                - id: cor-3_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Definimos un programa de auditorías externas de ciberseguridad con alcance basado en el perfil de riesgo.
                - id: cor-3_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Ejecutamos auditorías internas con una frecuencia programada para los sistemas críticos.
                - id: cor-3_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Ejecutamos auditorías externas con una frecuencia programada para los sistemas críticos.
                - id: cor-3_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Planificamos las auditorías definiendo criterios de selección de alcance y procedimientos de evaluación.
                - id: cor-3_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Garantizamos la independencia funcional de los auditores internos respecto a las áreas auditadas.
                - id: cor-3_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Garantizamos la independencia funcional de los auditores externos respecto a la compañía.
                - id: cor-3_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Contratamos periódicamente evaluaciones de ciberseguridad realizadas por terceros independientes y certificados.
                - id: cor-3_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Cubrimos con las evaluaciones externas al menos los sistemas más críticos con una frecuencia programada o ante cambios significativos en el entorno tecnológico.
                - id: cor-3_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Definimos en qué momentos se debe realizar el seguimiento y la medición de la seguridad de la información y ciberseguridad.
                - id: cor-3_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Definimos en qué momentos se deben analizar y evaluar los resultados obtenidos del seguimiento y medición de la seguridad de la información y ciberseguridad.
                - id: cor-3_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Mantenemos activos y actualizados uno o varios programas de auditoría interna.
                - id: cor-3_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: Planificamos con cuidado las pruebas de auditoría y otras actividades de evaluación en los sistemas en producción para minimizar el impacto.
                - id: cor-3_smt.n
                  name: item
                  props[2]:
                    - name: label
                      value: n
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-14
                  prose: Acordamos previamente con los gestores responsables la realización de pruebas de auditoría y otras actividades de evaluación en los sistemas.
                - id: cor-3_smt.o
                  name: item
                  props[2]:
                    - name: label
                      value: o
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-15
                  prose: "Incluimos en las evaluaciones externas pruebas de penetración, revisiones de arquitectura y evaluaciones de madurez."
                - id: cor-3_smt.p
                  name: item
                  props[2]:
                    - name: label
                      value: p
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-16
                  prose: Reportamos formalmente los hallazgos de auditoría.
                - id: cor-3_smt.q
                  name: item
                  props[2]:
                    - name: label
                      value: q
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-17
                  prose: Presentamos los resultados de las evaluaciones externas a la alta dirección.
        - id: cor-4
          title: Mejora Continua y Acciones Correctivas
          props[1]{name,value}:
            label,COR-4
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/cor/cor-4",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: cor-4_smt
              name: statement
              prose: "Es necesario gestionar formalmente las acciones correctivas y preventivas derivadas de auditorías, incidentes y evaluaciones de riesgo, conteniendo de inmediato cada incumplimiento y analizando su causa raíz para definir un plan de remediación con responsable y fecha. Es necesario validar la efectividad de las acciones implementadas, priorizarlas según su riesgo, y aplicar un ciclo de mejora continua que incorpore revisiones periódicas de la dirección sobre el desempeño del sistema de gestión. Es necesario comunicar los resultados de estas revisiones a los interesados, incorporarlos al roadmap de ciberseguridad, y documentar las lecciones aprendidas."
              parts[21]:
                - id: cor-4_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Implementamos un proceso formal de gestión de acciones correctivas y preventivas para todos los hallazgos provenientes de auditorías, incidentes y evaluaciones de riesgo, respondiendo de manera inmediata para controlar y corregir cada incumplimiento."
                - id: cor-4_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Definimos un plan de remediación con responsable y fecha para cada acción correctiva identificada.
                - id: cor-4_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Priorizamos las acciones correctivas según el nivel de riesgo asociado.
                - id: cor-4_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: "Implementamos un ciclo PDCA (Plan-Do-Check-Act) para la gestión sistemática de hallazgos, incidentes y oportunidades de mejora."
                - id: cor-4_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: "Planificamos acciones para gestionar los riesgos y aprovechar las oportunidades, con el fin de lograr una mejora continua."
                - id: cor-4_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Respondemos ante cualquier incumplimiento gestionando las consecuencias que haya generado.
                - id: cor-4_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: "Realizamos análisis de causa raíz utilizando una metodología; como por ejemplo: 5 Whys, el diagrama de Ishikawa, entre otros..."
                - id: cor-4_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Registramos todas las acciones correctivas y preventivas en el sistema de seguimiento.
                - id: cor-4_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Validamos la efectividad de las soluciones implementadas antes de dar cierre a las acciones correctivas.
                - id: cor-4_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Comunicamos los resultados de las revisiones gerenciales a los stakeholders relevantes.
                - id: cor-4_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Incorporamos los resultados de las revisiones gerenciales al roadmap de ciberseguridad.
                - id: cor-4_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: "Documentamos las lecciones aprendidas de los hallazgos, incidentes y oportunidades de mejora gestionadas."
                - id: cor-4_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: Incluimos en la revisión por parte de la dirección el seguimiento de las acciones que quedaron pendientes de revisiones anteriores.
                - id: cor-4_smt.n
                  name: item
                  props[2]:
                    - name: label
                      value: n
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-14
                  prose: Incluimos en la revisión por parte de la dirección los cambios en el entorno externo e interno que puedan afectar al sistema de gestión.
                - id: cor-4_smt.o
                  name: item
                  props[2]:
                    - name: label
                      value: o
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-15
                  prose: Incluimos en la revisión por parte de la dirección los cambios en lo que necesitan o esperan las partes interesadas.
                - id: cor-4_smt.p
                  name: item
                  props[2]:
                    - name: label
                      value: p
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-16
                  prose: Incluimos en la revisión por parte de la dirección los comentarios y opiniones recibidos de las partes interesadas.
                - id: cor-4_smt.q
                  name: item
                  props[2]:
                    - name: label
                      value: q
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-17
                  prose: Incluimos en la revisión por parte de la dirección las posibilidades identificadas para seguir mejorando el sistema de gestión.
                - id: cor-4_smt.r
                  name: item
                  props[2]:
                    - name: label
                      value: r
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-18
                  prose: Incluimos en los resultados de la revisión por parte de la dirección las decisiones tomadas sobre cómo mejorar continuamente el sistema de gestión.
                - id: cor-4_smt.s
                  name: item
                  props[2]:
                    - name: label
                      value: s
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-19
                  prose: Incluimos en los resultados de la revisión por parte de la dirección cualquier cambio que se considere necesario hacer en el sistema de gestión.
                - id: cor-4_smt.t
                  name: item
                  props[2]:
                    - name: label
                      value: t
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-20
                  prose: Revisamos si existen otros incumplimientos parecidos que también requieran acciones correctivas.
                - id: cor-4_smt.u
                  name: item
                  props[2]:
                    - name: label
                      value: u
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-21
                  prose: Actualizamos el sistema de gestión cuando sea necesario como resultado de las acciones correctivas aplicadas.
    - id: dia
      class: domain
      title: Ciberseguridad en Datos e Inteligencia Artificial
      props[1]{name,value}:
        label,DIA
      links[1]{href,rel,"media-type",text}:
        "https://kudo.divisioncero.com/framework/dia",reference,text/html,Documentación del dominio en el sitio Kudo
      parts[1]{id,name,prose}:
        dia_ovw,overview,"Dedicado a la seguridad, privacidad y gobierno de los datos organizacionales, así como a los controles específicos para el uso responsable de sistemas de Inteligencia Artificial. Cubre el inventario de datos, el mapeo de puntos de recolección, la gestión del ciclo de vida del dato, los controles de seguridad sobre información sensible, los tiempos de retención y el derecho al olvido, la ubicación geográfica de los datos, y los riesgos asociados a modelos de IA. Trata los datos como el activo más valioso de la organización (\"la joya de la corona\"), integrando controles de privacidad y promoviendo el uso de IA sin exposición de datos para reentrenamiento no autorizado."
      controls[7]:
        - id: dia-1
          title: Inventario de Datos
          props[1]{name,value}:
            label,DIA-1
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/dia/dia-1",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: dia-1_smt
              name: statement
              prose: "Es necesario mantener un catálogo completo y actualizado de todos los datos que la organización recopila, procesa, almacena y transmite, clasificándolos según su sensibilidad y criticidad. Es necesario automatizar el descubrimiento y clasificación de datos sensibles, validar los resultados con sus propietarios, y utilizar la clasificación como base para aplicar controles de seguridad diferenciados. Es necesario registrar para cada tipo de dato su propietario, ubicación y tiempo de retención, y mantener el catálogo actualizado ante cualquier cambio."
              parts[8]:
                - id: dia-1_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Mantenemos un catálogo completo y actualizado de todos los datos que la organización recopila, procesa, almacena y transmite."
                - id: dia-1_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Clasificamos los datos según su sensibilidad y criticidad en cuatro niveles: público, interno, confidencial y restringido."
                - id: dia-1_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: "Registramos para cada tipo de dato: propietario, custodio técnico, sistema de origen, ubicación, regulaciones aplicables y tiempo de retención."
                - id: dia-1_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Utilizamos las etiquetas de clasificación como base para la aplicación de controles de seguridad diferenciados.
                - id: dia-1_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: "Definimos las responsabilidades del propietario de datos (data owner) en cuanto a protección, acceso y retención."
                - id: dia-1_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Implementamos herramientas de descubrimiento y clasificación automática de datos sensibles en repositorios estructurados y no estructurados.
                - id: dia-1_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Validamos periódicamente con los propietarios los datos clasificados automáticamente.
                - id: dia-1_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Actualizamos el catálogo ante nuevos proyectos y lo revisamos integralmente con frecuencia programada.
        - id: dia-2
          title: Inventario de Puntos de Recolección de Datos
          props[1]{name,value}:
            label,DIA-2
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/dia/dia-2",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: dia-2_smt
              name: statement
              prose: "Es necesario identificar y documentar todos los puntos donde la organización recopila datos de usuarios, clientes, colaboradores y terceros, registrando para cada uno qué datos se obtienen, su finalidad, base legal y el flujo hacia los sistemas y terceros involucrados. Es necesario mantener actualizado el mapa de flujos de datos ante cualquier cambio, y utilizar este inventario como base para verificar el cumplimiento de las regulaciones de privacidad y gestionar el consentimiento de los titulares."
              parts[6]:
                - id: dia-2_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Identificamos y documentamos todos los puntos donde la organización recopila datos de usuarios, clientes, colaboradores y terceros."
                - id: dia-2_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Registramos en el inventario los puntos de recolección: formularios web, APIs, aplicaciones móviles, integraciones con terceros, cookies, rastreadores y sensores IoT."
                - id: dia-2_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: "Documentamos para cada punto de recolección: qué datos se obtienen, base legal del tratamiento, finalidad, flujo hacia sistemas de almacenamiento y terceros con acceso."
                - id: dia-2_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Utilizamos el inventario de puntos de recolección como base para el cumplimiento de regulaciones de privacidad.
                - id: dia-2_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Gestionamos el consentimiento de los titulares de datos a partir del inventario de puntos de recolección.
                - id: dia-2_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Mantenemos el mapa de flujos de datos (Data Flow Diagram) actualizado ante cambios en las aplicaciones.
        - id: dia-3
          title: Ciclo de Vida de los Datos
          props[1]{name,value}:
            label,DIA-3
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/dia/dia-3",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: dia-3_smt
              name: statement
              prose: "Es necesario definir y gestionar las etapas del ciclo de vida de los datos, desde su creación hasta su destrucción, estableciendo controles de seguridad y privacidad para cada una y asignando custodios responsables. Es necesario documentar los flujos de datos entre sistemas y terceros utilizando canales seguros y acuerdos de tratamiento de datos, y garantizar su destrucción segura y documentada al finalizar su período de retención. Es necesario revisar periódicamente el ciclo de vida para evitar retener datos más allá de lo necesario, y gestionar de forma segura los medios de almacenamiento durante todo su ciclo de uso."
              parts[10]:
                - id: dia-3_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Definimos y gestionamos las etapas del ciclo de vida de los datos: creación, almacenamiento, procesamiento, uso, compartición, archivado y destrucción."
                - id: dia-3_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Establecemos controles de seguridad y privacidad aplicables en cada etapa del ciclo de vida del dato.
                - id: dia-3_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Identificamos y capacitamos a los custodios de datos por sistema.
                - id: dia-3_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Documentamos los flujos de datos entre sistemas mediante diagramas de flujo de datos (DFD).
                - id: dia-3_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Exigimos un acuerdo de tratamiento de datos (DPA) vigente para cada transferencia de datos a terceros.
                - id: dia-3_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Diagramamos el ciclo de vida del dato del negocio.
                - id: dia-3_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: "Utilizamos canales cifrados y protocolos seguros (SFTP, HTTPS, MFT) para la transferencia de datos entre sistemas y hacia terceros."
                - id: dia-3_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: "Garantizamos la destrucción segura de datos al finalizar la necesidad de retención con evidencia documentada en sistemas primarios, respaldos y sistemas de terceros."
                - id: dia-3_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: "Gestionamos los medios de almacenamiento a lo largo de todo su ciclo de vida, desde su adquisición hasta su eliminación, siguiendo los criterios de clasificación de la información."
                - id: dia-3_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Revisamos periódicamente el ciclo de vida para garantizar que los datos no se retengan más allá de lo necesario.
        - id: dia-4
          title: Ciberseguridad en Información y Datos
          props[1]{name,value}:
            label,DIA-4
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/dia/dia-4",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: dia-4_smt
              name: statement
              prose: "Es necesario proteger los datos de la organización contra el acceso no autorizado, la modificación, la divulgación o la destrucción, aplicando controles de acceso y cifrado acordes a su clasificación. Es necesario enmascarar o eliminar los datos sensibles en los entornos no productivos, prevenir la fuga de información mediante herramientas de monitoreo y bloqueo, y definir las responsabilidades del propietario de cada dato frente a su protección y acceso, incluyendo la atención de solicitudes de terceros o autoridades. Es necesario establecer normas de uso aceptable y procedimientos de manejo de la información, clasificarla y etiquetarla de forma consistente, y definir reglas y acuerdos formales para su transferencia, protegiendo los registros de la organización frente a pérdida o divulgación indebida."
              parts[21]:
                - id: dia-4_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Protegemos los datos de la organización contra acceso no autorizado, modificación, divulgación o destrucción."
                - id: dia-4_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Prohibimos el uso de datos reales de producción en ambientes de desarrollo o pruebas sin protección aplicada.
                - id: dia-4_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Establecemos procedimientos formales ante solicitudes de acceso a datos por parte de autoridades o terceros.
                - id: dia-4_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Identificamos las normas sobre cómo se puede usar de forma aceptable la información y los activos relacionados.
                - id: dia-4_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Documentamos las normas sobre cómo se puede usar de forma aceptable la información y los activos relacionados.
                - id: dia-4_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Aplicamos las normas sobre cómo se puede usar de forma aceptable la información y los activos relacionados.
                - id: dia-4_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Identificamos los procedimientos para gestionar y manejar correctamente la información y los activos relacionados.
                - id: dia-4_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Documentamos los procedimientos para gestionar y manejar correctamente la información y los activos relacionados.
                - id: dia-4_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Aplicamos los procedimientos para gestionar y manejar correctamente la información y los activos relacionados.
                - id: dia-4_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: "Clasificamos la información según qué tan confidencial, íntegra y disponible debe estar, tomando en cuenta las necesidades de seguridad de la organización y lo que esperan las partes interesadas."
                - id: dia-4_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Desarrollamos procedimientos adecuados para etiquetar la información según el esquema de clasificación definido.
                - id: dia-4_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Aplicamos los procedimientos para etiquetar la información según el esquema de clasificación definido.
                - id: dia-4_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: "Contamos con reglas claras para transferir información a través de cualquier medio, tanto dentro de la organización como hacia otras partes externas."
                - id: dia-4_smt.n
                  name: item
                  props[2]:
                    - name: label
                      value: n
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-14
                  prose: "Contamos con procedimientos claros para transferir información a través de cualquier medio, tanto dentro de la organización como hacia otras partes externas."
                - id: dia-4_smt.o
                  name: item
                  props[2]:
                    - name: label
                      value: o
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-15
                  prose: "Contamos con acuerdos formales para transferir información a través de cualquier medio, tanto dentro de la organización como hacia otras partes externas."
                - id: dia-4_smt.p
                  name: item
                  props[2]:
                    - name: label
                      value: p
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-16
                  prose: "Protegemos los registros de la organización contra pérdida, destrucción, falsificación, accesos no autorizados y divulgaciones indebidas."
                - id: dia-4_smt.q
                  name: item
                  props[2]:
                    - name: label
                      value: q
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-17
                  prose: Implementamos controles de acceso basados en la clasificación de datos (RBAC/ABAC) para datos confidenciales y restringidos.
                - id: dia-4_smt.r
                  name: item
                  props[2]:
                    - name: label
                      value: r
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-18
                  prose: Ciframos los datos sensibles en reposo y en tránsito.
                - id: dia-4_smt.s
                  name: item
                  props[2]:
                    - name: label
                      value: s
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-19
                  prose: Enmascaramos o pseudonimizamos los datos personales y sensibles antes de su uso en entornos no productivos.
                - id: dia-4_smt.t
                  name: item
                  props[2]:
                    - name: label
                      value: t
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-20
                  prose: Implementamos soluciones DLP en endpoints y en el correo electrónico corporativo para detectar y bloquear la transmisión no autorizada de datos sensibles.
                - id: dia-4_smt.u
                  name: item
                  props[2]:
                    - name: label
                      value: u
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-21
                  prose: Monitoreamos el acceso a datos críticos mediante Análisis del comportamiento de usuarios y entidades (UEBA) con alertas ante comportamientos anómalos.
        - id: dia-5
          title: Tiempo de Retención de Datos y Derecho al Olvido
          props[1]{name,value}:
            label,DIA-5
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/dia/dia-5",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: dia-5_smt
              name: statement
              prose: "Es necesario definir y aplicar una política de retención de datos por categoría, acorde a la base legal y los requisitos regulatorios aplicables, y eliminar automáticamente la información al vencer su período de retención dejando evidencia del proceso. Es necesario implementar un proceso formal para atender los derechos de los titulares de datos —acceso, rectificación, supresión, portabilidad y oposición—, verificando su identidad, coordinando su ejecución con sistemas y terceros, y respondiendo dentro de los plazos regulatorios. Es necesario garantizar la eliminación segura de la información en sistemas, respaldos y medios de almacenamiento cuando ya no sea necesaria o antes de su reutilización."
              parts[12]:
                - id: dia-5_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Definimos y aplicamos una política de retención de datos documentada por categoría, basada en la base legal del tratamiento y los requisitos regulatorios aplicables."
                - id: dia-5_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Implementamos un proceso formal para atender solicitudes de derechos de los titulares: acceso, rectificación, supresión, portabilidad y oposición."
                - id: dia-5_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: "Verificamos la identidad del solicitante, registramos la solicitud y coordinamos con sistemas y terceros para ejecutar el derecho ejercido."
                - id: dia-5_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Comunicamos la respuesta al titular dentro de los plazos regulatorios aplicables.
                - id: dia-5_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Implementamos mecanismos de eliminación automática de datos al vencimiento de su período de retención en sistemas primarios y respaldos.
                - id: dia-5_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: "Eliminamos de forma segura la información almacenada en sistemas, dispositivos y medios de almacenamiento cuando ya no sea necesaria."
                - id: dia-5_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Mantenemos registros de eliminación como evidencia de cumplimiento regulatorio.
                - id: dia-5_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Revisamos la política de retención anualmente y ante cambios regulatorios.
                - id: dia-5_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: "Verificamos la eliminación en sistemas primarios, respaldos y sistemas de terceros al ejercer el derecho de supresión."
                - id: dia-5_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Mantenemos un registro completo de las solicitudes de derechos atendidas.
                - id: dia-5_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Verificamos que todos los medios de almacenamiento hayan eliminado o sobrescrito de forma segura los datos sensibles y el software con licencia antes de desecharlos.
                - id: dia-5_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Verificamos que todos los medios de almacenamiento hayan eliminado o sobrescrito de forma segura los datos sensibles y el software con licencia antes de reutilizarlos.
        - id: dia-6
          title: Ubicación de Información y Datos
          props[1]{name,value}:
            label,DIA-6
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/dia/dia-6",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: dia-6_smt
              name: statement
              prose: "Es necesario documentar y mantener actualizado el mapa de ubicaciones donde se almacenan y procesan los datos de la organización, identificando las restricciones de soberanía y residencia aplicables a cada tipo de dato. Es necesario implementar controles técnicos que impidan el almacenamiento en regiones no autorizadas, y evaluar, autorizar y documentar formalmente cualquier transferencia internacional de datos junto con su mecanismo legal de cumplimiento. Es necesario monitorear continuamente estas transferencias y evaluar el impacto de residencia ante nuevas ubicaciones de almacenamiento."
              parts[9]:
                - id: dia-6_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Documentamos y mantenemos actualizado el mapa de ubicaciones geográficas donde se almacenan y procesan los datos de la organización.
                - id: dia-6_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Identificamos las restricciones de soberanía y residencia de datos aplicables por regulación para cada tipo de dato.
                - id: dia-6_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Validamos con el equipo de seguridad y compliance la selección de regiones cloud para datos con requisitos de residencia.
                - id: dia-6_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Evaluamos y autorizamos formalmente las transferencias de datos fuera de las jurisdicciones permitidas.
                - id: dia-6_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: "Documentamos el mecanismo legal de cumplimiento aplicable en cada transferencia internacional: cláusulas contractuales tipo, normas corporativas vinculantes o decisión de adecuación."
                - id: dia-6_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Exigimos un DPA actualizado para las transferencias a terceros en el extranjero que refleje los mecanismos de cumplimiento aplicables.
                - id: dia-6_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Implementamos controles técnicos que impidan el almacenamiento de datos en regiones no autorizadas.
                - id: dia-6_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Monitoreamos continuamente las transferencias de datos para detectar movimientos hacia ubicaciones no autorizadas.
                - id: dia-6_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Evaluamos el impacto de residencia de datos ante la incorporación de nuevas ubicaciones de almacenamiento.
        - id: dia-7
          title: Ciberseguridad en Modelos de Inteligencia Artificial
          props[1]{name,value}:
            label,DIA-7
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/dia/dia-7",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: dia-7_smt
              name: statement
              prose: "Es necesario establecer controles de seguridad y uso responsable para el desarrollo, implementación y operación de modelos de inteligencia artificial, evaluando los riesgos de seguridad, privacidad, sesgo y cumplimiento regulatorio antes de adoptar cualquier modelo y requiriendo aprobación formal para los de mayor riesgo. Es necesario prevenir la exposición de datos personales o confidenciales en las interacciones con modelos de IA, tanto en las entradas como en las salidas, y restringir el uso de información organizacional para el reentrenamiento de modelos de terceros. Es necesario incorporar las vulnerabilidades propias de la IA en los programas de evaluación de seguridad, y gestionar la cadena de suministro de los modelos utilizados."
              parts[10]:
                - id: dia-7_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Establecemos controles de seguridad y uso responsable para el desarrollo, implementación y operación de modelos de IA en la organización."
                - id: dia-7_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Realizamos una evaluación de riesgos antes de adoptar o desplegar cualquier modelo de IA, ya sea desarrollado internamente, mediante APIs de terceros o modelos open source."
                - id: dia-7_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: "Analizamos en la evaluación de riesgos: riesgos de seguridad, privacidad, sesgo, equidad y cumplimiento regulatorio."
                - id: dia-7_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Requerimos aprobación del comité de gobernanza antes del despliegue de modelos de IA de alto riesgo.
                - id: dia-7_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Prohibimos incluir datos personales o confidenciales en prompts enviados a modelos de IA externos sin evaluación previa.
                - id: dia-7_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Restringimos el uso de datos organizacionales para el reentrenamiento de modelos de terceros.
                - id: dia-7_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: "Gestionamos la cadena de suministro de modelos de IA evaluando a proveedores, APIs de terceros y modelos open source."
                - id: dia-7_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Implementamos controles de filtrado de outputs para prevenir la exfiltración de datos mediante sistemas de IA.
                - id: dia-7_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: "Incluimos las vulnerabilidades específicas de IA (prompt injection, jailbreaking, model inversion, entre otras...) en los programas de evaluación de seguridad."
                - id: dia-7_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Protegemos que los datos no sean usados para reentrenamiento de la IA.
    - id: thp
      class: domain
      title: Ciberseguridad en Talento Humano y Proveedores
      props[1]{name,value}:
        label,THP
      links[1]{href,rel,"media-type",text}:
        "https://kudo.divisioncero.com/framework/thp",reference,text/html,Documentación del dominio en el sitio Kudo
      parts[1]{id,name,prose}:
        thp_ovw,overview,"Dominio que gestiona el factor humano y la cadena de suministro como vectores críticos de riesgo en Ciberseguridad. Comprende la capacitación y entrenamiento continuo en ciberseguridad para colaboradores, los controles asociados al trabajo remoto, el inventario y evaluación de la cadena de suministro; gestionando el modelo de responsabilidad compartida con proveedores y terceros. Incluye campañas de concienciación, simulaciones de phishing y la automatización del aprovisionamiento y desaprovisionamiento de usuarios. Reconoce al ser humano como el vector de ataque más frecuentemente explotado, y a los proveedores como una extensión del perímetro de riesgo organizacional."
      controls[4]:
        - id: thp-1
          title: Capacitación de Ciberseguridad
          props[1]{name,value}:
            label,THP-1
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/thp/thp-1",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: thp-1_smt
              name: statement
              prose: "Es necesario implementar un programa de formación continua en ciberseguridad para todos los colaboradores, reconociendo al factor humano como el principal vector de ataque, e impartir capacitación especializada a los roles con mayor responsabilidad o exposición en seguridad. Es necesario realizar simulaciones de phishing con frecuencia programada, aplicar formación correctiva a quienes interactúen con ellas, y medir la efectividad del programa reportando sus resultados al comité de seguridad. Es necesario asegurar que todo el personal conozca y comprenda la política de seguridad de la información y sus responsabilidades, incluyendo aquellas que persisten al finalizar la relación laboral, y contar con un proceso disciplinario formal ante incumplimientos."
              parts[18]:
                - id: thp-1_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Implementamos un programa de formación continua en ciberseguridad para todos los colaboradores de la organización.
                - id: thp-1_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Completamos los cursos de inducción en ciberseguridad para nuevos colaboradores en un tiempo definido.
                - id: thp-1_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Realizamos capacitación anual de actualización en ciberseguridad para toda la plantilla.
                - id: thp-1_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Impartimos formación especializada a los roles con responsabilidades de seguridad o críticos en seguridad.
                - id: thp-1_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Aplicamos formación correctiva inmediata a los colaboradores que hacen clic o proporcionar credenciales en el phishing simulado.
                - id: thp-1_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Impartimos charlas periódicas sobre amenazas emergentes.
                - id: thp-1_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Identificamos los conocimientos y habilidades que deben tener las personas cuyo trabajo impacta en la seguridad de la información y tomamos acciones para cerrar las brechas de competencia identificadas.
                - id: thp-1_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: "Nos aseguramos de que todas las personas de la organización conozcan y entiendan la política de seguridad de la información, cómo su trabajo contribuye al funcionamiento del sistema de gestión y qué puede ocurrir si no cumplen los requisitos establecidos."
                - id: thp-1_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Nos aseguramos de que el personal reciba actualizaciones periódicas sobre la política de seguridad de la información y los procedimientos relacionados con su puesto.
                - id: thp-1_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: Incluimos en los contratos de trabajo las responsabilidades del personal y de la organización en materia de seguridad de la información.
                - id: thp-1_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: "Contamos con un proceso disciplinario formal que define las acciones a tomar cuando alguien cause una brecha de seguridad, y lo comunicamos a los empleados y partes interesadas que corresponda."
                - id: thp-1_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: "Definimos, aseguramos el cumplimiento y comunicamos al personal y partes interesadas las responsabilidades en seguridad de la información que continúan vigentes cuando alguien deja o cambia de puesto en la organización."
                - id: thp-1_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: "Impartimos a toda la compañía un curso de ciberseguridad con currículo definido que incluya modalidades de cibercrimen frecuente, protección de datos e inteligencia artificial."
                - id: thp-1_smt.n
                  name: item
                  props[2]:
                    - name: label
                      value: n
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-14
                  prose: Realizamos simulaciones de phishing internas con una frecuencia programada para evaluar la conciencia de seguridad.
                - id: thp-1_smt.o
                  name: item
                  props[2]:
                    - name: label
                      value: o
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-15
                  prose: Analizamos los resultados de las simulaciones para identificar grupos de alto riesgo y adaptar el programa de concienciación.
                - id: thp-1_smt.p
                  name: item
                  props[2]:
                    - name: label
                      value: p
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-16
                  prose: Definimos tasas de aprobación mínimas con un porcentaje definido y hacemos seguimiento de completitud por área.
                - id: thp-1_smt.q
                  name: item
                  props[2]:
                    - name: label
                      value: q
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-17
                  prose: Reportamos las métricas de efectividad del programa de formación al comité de seguridad.
                - id: thp-1_smt.r
                  name: item
                  props[2]:
                    - name: label
                      value: r
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-18
                  prose: Guardamos evidencia documentada que demuestra que el personal cuenta con las competencias necesarias en seguridad de la información.
        - id: thp-2
          title: Trabajo Remoto
          props[1]{name,value}:
            label,THP-2
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/thp/thp-2",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: thp-2_smt
              name: statement
              prose: "Es necesario establecer controles de seguridad que garanticen a los colaboradores remotos el mismo nivel de protección que en las instalaciones físicas, exigiendo conexión segura y autenticación multifactor para acceder a los recursos corporativos. Es necesario gestionar los dispositivos de trabajo remoto mediante soluciones centralizadas que apliquen cifrado, bloqueo y restricciones de uso, y aprobar únicamente herramientas de colaboración con configuración corporativa segura. Es necesario evaluar periódicamente el cumplimiento de estas políticas y proteger la información que se accede, procesa o almacena fuera de las instalaciones de la organización."
              parts[11]:
                - id: thp-2_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Establecemos controles de seguridad para garantizar que los colaboradores remotos mantengan el mismo nivel de protección que en las instalaciones físicas.
                - id: thp-2_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: Evaluamos y aprobamos con configuración corporativa segura las herramientas de colaboración en la nube de uso oficial.
                - id: thp-2_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: Prohibimos el uso de redes Wi-Fi públicas sin VPN activa.
                - id: thp-2_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Comunicamos y hacemos cumplir la política de escritorio limpio en entornos domésticos.
                - id: thp-2_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Aplicamos medidas de seguridad para proteger la información a la que se acceda cuando el personal trabaje de forma remota.
                - id: thp-2_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Aplicamos medidas de seguridad para proteger la información que se procese cuando el personal trabaje de forma remota.
                - id: thp-2_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Aplicamos medidas de seguridad para proteger la información que se almacene cuando el personal trabaje de forma remota.
                - id: thp-2_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: "Exigimos VPN corporativa con MFA en la autenticación para todo acceso remoto, red corporativa y recursos corporativos."
                - id: thp-2_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Gestionamos los dispositivos de trabajo remoto mediante soluciones MDM/UEM con políticas de seguridad aplicadas.
                - id: thp-2_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: "Exigimos cifrado de disco, bloqueo por inactividad y restricción de aplicaciones no autorizadas en todos los dispositivos remotos."
                - id: thp-2_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Realizamos evaluaciones periódicas de cumplimiento de políticas de seguridad en dispositivos remotos.
        - id: thp-3
          title: Inventario de la Cadena de Suministro
          props[1]{name,value}:
            label,THP-3
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/thp/thp-3",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: thp-3_smt
              name: statement
              prose: "Es necesario definir procesos para gestionar los riesgos de seguridad asociados a la cadena de suministro, asegurando que los productos y servicios externos que afecten a la organización estén debidamente controlados. Es necesario mantener un registro completo y actualizado de todos los proveedores, socios y terceros con acceso a sistemas, datos o infraestructura, clasificándolos según su criticidad y nivel de acceso, y realizar due diligence de seguridad antes de su incorporación verificando sus certificaciones. Es necesario revisar periódicamente este inventario, verificar los antecedentes del personal según su nivel de acceso, y asegurar la devolución de los activos organizacionales al finalizar cualquier relación."
              parts[12]:
                - id: thp-3_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: "Mantenemos un registro completo y actualizado de todos los proveedores, socios y terceros con acceso a sistemas, datos o infraestructura de la organización."
                - id: thp-3_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Incluimos en el inventario a los proveedores de software, servicios cloud, servicios de seguridad, integradores y contratistas."
                - id: thp-3_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: "Registramos para cada proveedor: nombre, tipo de servicio, nivel de acceso, datos compartidos, criticidad, responsable interno, certificaciones vigentes y fecha de última evaluación."
                - id: thp-3_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Realizamos due diligence de seguridad como parte obligatoria del proceso de incorporación de nuevos proveedores.
                - id: thp-3_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Evaluamos a los nuevos proveedores mediante cuestionarios definidos y verificamos sus certificaciones relevantes.
                - id: thp-3_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Clasificamos los proveedores por nivel de criticidad y acceso para determinar la profundidad del due diligence requerido.
                - id: thp-3_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: "Nos aseguramos de que los procesos, productos o servicios externos que afecten al sistema de gestión de seguridad de la información estén debidamente controlados."
                - id: thp-3_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Nos aseguramos de que empleados y terceros devuelvan todos los activos de la organización que tengan en su poder cuando cambien de rol o finalicen su relación con la organización.
                - id: thp-3_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Definimos y aplicamos procesos y procedimientos para gestionar los riesgos de seguridad asociados a la cadena de suministro de productos y servicios tecnológicos.
                - id: thp-3_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: "Verificamos los antecedentes de todos los candidatos antes de contratarlos, cumpliendo con las leyes y normas aplicables y de forma proporcional al nivel de acceso a la información que tendrán."
                - id: thp-3_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Revisamos el inventario de proveedores con una frecuencia definida para identificar los que ya no cumplen los requisitos de seguridad.
                - id: thp-3_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: "Verificamos los antecedentes del personal de forma continua, cumpliendo con las leyes y normas aplicables y según los riesgos identificados."
        - id: thp-4
          title: Modelo de Responsabilidad Compartida en la Cadena de Suministro
          props[1]{name,value}:
            label,THP-4
          links[1]{href,rel,"media-type",text}:
            "https://kudo.divisioncero.com/framework/thp/thp-4",reference,text/html,Documentación del control en el sitio Kudo
          parts[1]:
            - id: thp-4_smt
              name: statement
              prose: "Es necesario definir claramente las responsabilidades de ciberseguridad entre la organización y cada proveedor o tercero, clasificándolos por nivel de riesgo y estableciendo los requisitos mínimos de seguridad y la frecuencia de evaluación que corresponda a cada nivel. Es necesario incluir en los contratos obligaciones de notificación de incidentes, derecho de auditoría, eliminación segura de datos y responsabilidad ante brechas, revisándolos con el equipo de seguridad antes de su firma, y gestionar los acuerdos de confidencialidad necesarios. Es necesario evaluar y monitorear periódicamente a los proveedores más críticos, generar planes de remediación ante desviaciones, y revocar de inmediato todos sus accesos al finalizar la relación, verificando la eliminación segura de la información compartida."
              parts[17]:
                - id: thp-4_smt.a
                  name: item
                  props[2]:
                    - name: label
                      value: a
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-1
                  prose: Definimos claramente las responsabilidades de ciberseguridad entre la organización y cada proveedor o tercero.
                - id: thp-4_smt.b
                  name: item
                  props[2]:
                    - name: label
                      value: b
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-2
                  prose: "Clasificamos a los proveedores y terceros en niveles de riesgo: crítico, alto, medio y bajo."
                - id: thp-4_smt.c
                  name: item
                  props[2]:
                    - name: label
                      value: c
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-3
                  prose: "Definimos requisitos mínimos de seguridad para cada nivel de riesgo: certificaciones obligatorias, políticas exigibles y controles técnicos requeridos."
                - id: thp-4_smt.d
                  name: item
                  props[2]:
                    - name: label
                      value: d
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-4
                  prose: Definimos la frecuencia de evaluación de cumplimiento según el nivel de riesgo de cada proveedor.
                - id: thp-4_smt.e
                  name: item
                  props[2]:
                    - name: label
                      value: e
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-5
                  prose: Incluimos en los contratos con proveedores la obligación de notificar incidentes de seguridad en un tiempo definido.
                - id: thp-4_smt.f
                  name: item
                  props[2]:
                    - name: label
                      value: f
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-6
                  prose: Incluimos en los contratos el derecho de auditoría o acceso a evaluaciones de terceros equivalentes.
                - id: thp-4_smt.g
                  name: item
                  props[2]:
                    - name: label
                      value: g
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-7
                  prose: Exigimos contractualmente la eliminación segura de datos organizacionales al término del contrato.
                - id: thp-4_smt.h
                  name: item
                  props[2]:
                    - name: label
                      value: h
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-8
                  prose: Establecemos contractualmente la responsabilidad del proveedor ante brechas de seguridad causadas por su parte.
                - id: thp-4_smt.i
                  name: item
                  props[2]:
                    - name: label
                      value: i
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-9
                  prose: Revisamos los contratos con proveedores junto al equipo de seguridad antes de su firma.
                - id: thp-4_smt.j
                  name: item
                  props[2]:
                    - name: label
                      value: j
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-10
                  prose: "Identificamos y aplicamos procesos y procedimientos para gestionar los riesgos de seguridad de la información que surgen del uso de productos o servicios de proveedores, definiendo y acordando con cada uno los requisitos de seguridad que correspondan según el tipo de relación establecida."
                - id: thp-4_smt.k
                  name: item
                  props[2]:
                    - name: label
                      value: k
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-11
                  prose: Revocamos de inmediato todos los accesos lógicos y físicos al terminar la relación con un proveedor.
                - id: thp-4_smt.l
                  name: item
                  props[2]:
                    - name: label
                      value: l
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-12
                  prose: Evaluamos periódicamente a los proveedores críticos y de alto riesgo para verificar el cumplimiento de sus certificaciones y requisitos de seguridad.
                - id: thp-4_smt.m
                  name: item
                  props[2]:
                    - name: label
                      value: m
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-13
                  prose: Generamos informes de cumplimiento con acciones de remediación ante desviaciones detectadas en las evaluaciones.
                - id: thp-4_smt.n
                  name: item
                  props[2]:
                    - name: label
                      value: n
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-14
                  prose: Verificamos la eliminación segura de datos organizacionales en los sistemas del proveedor al finalizar el contrato.
                - id: thp-4_smt.o
                  name: item
                  props[2]:
                    - name: label
                      value: o
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-15
                  prose: "Monitorizamos, revisamos y gestionamos de forma regular los cambios en las prácticas de seguridad y en la prestación de servicios de los proveedores."
                - id: thp-4_smt.p
                  name: item
                  props[2]:
                    - name: label
                      value: p
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-16
                  prose: "Identificamos, documentamos y revisamos regularmente los acuerdos de confidencialidad o no divulgación (NDA) que reflejen las necesidades de protección de la información de la organización, y nos aseguramos de que el personal y las partes interesadas relevantes los firmen."
                - id: thp-4_smt.q
                  name: item
                  props[2]:
                    - name: label
                      value: q
                    - name: requirement-id
                      ns: "https://kudo.divisioncero.com/framework/oscal"
                      value: req-17
                  prose: "Supervisamos, monitorizamos y revisamos las actividades de desarrollo de sistemas de información cuando estas sean realizadas por terceros externos."
  "back-matter":
    resources[1]:
      - uuid: 358d959e-287a-402d-9a5e-0a2c228f6dab
        title: Kudo - Sitio de documentación
        rlinks[1]{href}:
          "https://kudo.divisioncero.com/framework"